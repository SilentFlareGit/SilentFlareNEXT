---
import MainGridLayout from "@layouts/MainGridLayout.astro";
---

<MainGridLayout title="Not found" description="The requested page could not be found.">
    <div class="card-base rounded-[var(--radius-large)] px-6 md:px-9 py-8">
        <h1 class="text-3xl font-bold text-90 mb-3">Not found</h1>
        <p class="text-75 mb-5">The page you requested does not exist or is no longer published.</p>
        <a href="/" class="btn-regular px-4 h-10 inline-flex">Back to home</a>
    </div>
</MainGridLayout>
