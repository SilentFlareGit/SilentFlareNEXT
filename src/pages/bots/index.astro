---
const apiBase =
	import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.silentflare.com";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Telegram Bot Management</title>
		<meta name="description" content="SilentFlare bot operations dashboard" />
		<style>
			:root {
				color-scheme: light;
				--bg: #eef3f7;
				--rail: #111827;
				--rail-soft: #1f2937;
				--surface: #ffffff;
				--surface-soft: #f7f9fc;
				--surface-tint: #edf5fc;
				--line: #d7e0ea;
				--line-soft: #e7edf4;
				--text: #121a27;
				--muted: #667386;
				--subtle: #8a96a8;
				--blue: #2563eb;
				--blue-dark: #1d4ed8;
				--blue-soft: #e8f1ff;
				--green: #12834c;
				--green-soft: #e9f8f0;
				--amber: #9a6500;
				--amber-soft: #fff7df;
				--red: #b42318;
				--red-soft: #fff1f0;
				--shadow: 0 18px 46px rgba(29, 45, 65, 0.1);
				--radius: 8px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				overflow: hidden;
				background: var(--bg);
				color: var(--text);
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
					sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			button,
			input {
				font: inherit;
				letter-spacing: 0;
			}

			button {
				cursor: pointer;
			}

			button:disabled {
				cursor: not-allowed;
				opacity: 0.56;
			}

			h1,
			h2,
			h3,
			p {
				margin: 0;
			}

			.icon {
				width: 1rem;
				height: 1rem;
				flex: none;
				stroke: currentColor;
				stroke-width: 2;
				stroke-linecap: round;
				stroke-linejoin: round;
				fill: none;
			}

			.app {
				display: grid;
				grid-template-columns: 13rem minmax(0, 1fr);
				gap: 0.75rem;
				height: 100vh;
				padding: 0.75rem;
			}

			.rail {
				display: grid;
				grid-template-rows: auto 1fr auto;
				min-width: 0;
				overflow: hidden;
				border-radius: 14px;
				background: linear-gradient(180deg, #111827, #0c1420);
				color: #f8fafc;
				padding: 0.85rem;
			}

			.brand {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				min-width: 0;
				padding: 0.25rem 0.15rem 1rem;
			}

			.brand-mark {
				display: grid;
				width: 2.35rem;
				height: 2.35rem;
				place-items: center;
				border-radius: 8px;
				background: var(--blue);
				color: #ffffff;
				font-weight: 850;
			}

			.brand strong,
			.brand span {
				display: block;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.brand strong {
				font-size: 0.93rem;
			}

			.brand span {
				margin-top: 0.12rem;
				color: #a7b2c3;
				font-size: 0.74rem;
			}

			.nav {
				display: grid;
				gap: 0.35rem;
				align-content: start;
			}

			.nav-label {
				margin: 0.5rem 0.45rem 0.35rem;
				color: #8f9bad;
				font-size: 0.68rem;
				font-weight: 800;
				text-transform: uppercase;
			}

			.nav button,
			.rail-action {
				display: grid;
				grid-template-columns: 1.1rem minmax(0, 1fr);
				align-items: center;
				gap: 0.65rem;
				width: 100%;
				min-height: 2.55rem;
				border: 0;
				border-radius: var(--radius);
				background: transparent;
				color: #cbd5e1;
				padding: 0 0.65rem;
				font-size: 0.85rem;
				text-align: left;
			}

			.nav button.active,
			.nav button:hover,
			.rail-action:hover {
				background: #243244;
				color: #ffffff;
			}

			.rail-status {
				display: grid;
				gap: 0.85rem;
				border: 1px solid rgba(203, 213, 225, 0.18);
				border-radius: 12px;
				padding: 0.85rem;
				color: #dbe6f4;
			}

			.rail-status .status-line {
				color: #86efac;
				font-size: 0.82rem;
				font-weight: 760;
			}

			.rail-status small {
				display: block;
				margin-top: 0.24rem;
				color: #a7b2c3;
				font-size: 0.74rem;
				line-height: 1.45;
			}

			.rail-action {
				border: 1px solid rgba(203, 213, 225, 0.24);
				justify-content: start;
			}

			.shell {
				display: grid;
				grid-template-rows: auto minmax(0, 1fr);
				min-width: 0;
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: 14px;
				background: var(--surface);
				box-shadow: var(--shadow);
			}

			.topbar {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 1rem;
				align-items: center;
				min-height: 4.6rem;
				border-bottom: 1px solid var(--line);
				padding: 0.9rem 1.5rem;
			}

			.topbar h1 {
				font-size: clamp(1.25rem, 2vw, 1.72rem);
				font-weight: 820;
				line-height: 1.15;
			}

			.topbar p {
				margin-top: 0.22rem;
				color: var(--muted);
				font-size: 0.86rem;
				line-height: 1.4;
			}

			.top-actions {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-end;
				gap: 0.7rem;
			}

			.status-pill,
			.small-pill {
				display: inline-flex;
				min-height: 2.15rem;
				align-items: center;
				justify-content: center;
				gap: 0.45rem;
				border: 1px solid #b9e4c8;
				border-radius: var(--radius);
				background: var(--green-soft);
				color: var(--green);
				padding: 0.45rem 0.75rem;
				font-size: 0.78rem;
				font-weight: 760;
				white-space: nowrap;
			}

			.status-pill::before,
			.small-pill::before {
				width: 0.45rem;
				height: 0.45rem;
				border-radius: 999px;
				background: currentColor;
				content: "";
			}

			.status-pill[data-tone="error"],
			.small-pill[data-tone="error"] {
				border-color: #f0bbb5;
				background: var(--red-soft);
				color: var(--red);
			}

			.status-pill[data-tone="warning"],
			.small-pill[data-tone="warning"] {
				border-color: #f0d593;
				background: var(--amber-soft);
				color: var(--amber);
			}

			.last-updated {
				color: var(--muted);
				font-size: 0.78rem;
			}

			.workspace {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 18rem;
				min-height: 0;
				overflow: hidden;
			}

			.main {
				display: grid;
				grid-template-rows: auto auto minmax(0, 1fr) auto;
				min-width: 0;
				min-height: 0;
				overflow: auto;
				padding: 1rem 1.5rem;
			}

			.diagnostics {
				min-height: 0;
				overflow: auto;
				border-left: 1px solid var(--line);
				background: var(--surface-soft);
				padding: 1rem;
			}

			.selector {
				display: grid;
				grid-template-columns: auto minmax(0, 1fr);
				gap: 0.85rem;
				align-items: center;
				margin-bottom: 1rem;
			}

			.selector-label {
				color: var(--text);
				font-size: 0.84rem;
				font-weight: 720;
			}

			.bot-list {
				display: grid;
				gap: 0.55rem;
			}

			.bot-card {
				display: grid;
				grid-template-columns: 1.9rem minmax(0, 1fr) auto;
				align-items: center;
				gap: 0.75rem;
				width: 100%;
				min-height: 3.15rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				color: var(--text);
				padding: 0.55rem 0.7rem;
				text-align: left;
			}

			.bot-card:hover,
			.bot-card[aria-pressed="true"] {
				border-color: #b8d2f8;
				background: #f8fbff;
			}

			.bot-icon,
			.step-num {
				display: grid;
				width: 1.9rem;
				height: 1.9rem;
				place-items: center;
				border-radius: 999px;
				background: var(--blue);
				color: #ffffff;
				font-weight: 850;
			}

			.bot-card strong,
			.bot-card small {
				display: block;
				min-width: 0;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.bot-card small {
				margin-top: 0.12rem;
				color: var(--muted);
				font-size: 0.74rem;
			}

			.chip {
				border: 1px solid var(--line);
				border-radius: 999px;
				background: #f8fafc;
				color: var(--muted);
				padding: 0.22rem 0.55rem;
				font-size: 0.72rem;
				font-weight: 760;
			}

			.chip[data-tone="success"] {
				border-color: #bbe4ca;
				background: var(--green-soft);
				color: var(--green);
			}

			.primary-grid {
				display: grid;
				grid-template-columns: minmax(20rem, 0.95fr) minmax(21rem, 1.05fr);
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.panel {
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				overflow: hidden;
			}

			.panel-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				min-height: 3.1rem;
				border-bottom: 1px solid var(--line-soft);
				padding: 0.7rem 0.85rem;
			}

			.panel-title {
				display: flex;
				align-items: center;
				gap: 0.65rem;
				min-width: 0;
			}

			.panel-title h2 {
				font-size: 1rem;
				font-weight: 800;
				line-height: 1.2;
			}

			.panel-body {
				padding: 0.9rem;
			}

			.auth-flow {
				display: grid;
				gap: 0.85rem;
			}

			.auth-state {
				display: grid;
				grid-template-columns: 4.4rem minmax(0, 1fr);
				gap: 1rem;
				align-items: center;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #fbfdff;
				padding: 0.85rem;
			}

			.auth-illustration {
				display: grid;
				width: 4.2rem;
				height: 4.2rem;
				place-items: center;
				border-radius: 999px;
				background: var(--blue-soft);
				color: var(--blue);
			}

			.auth-state h3 {
				font-size: 1rem;
				font-weight: 820;
			}

			.auth-state p {
				margin-top: 0.24rem;
				color: var(--muted);
				font-size: 0.84rem;
				line-height: 1.45;
			}

			.progress {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.5rem;
				align-items: start;
			}

			.progress-step {
				display: grid;
				gap: 0.35rem;
				color: var(--muted);
				font-size: 0.72rem;
				text-align: center;
			}

			.progress-dot {
				display: grid;
				width: 2rem;
				height: 2rem;
				place-items: center;
				justify-self: center;
				border: 1px solid var(--line);
				border-radius: 999px;
				background: #ffffff;
				color: var(--muted);
			}

			.progress-step.active .progress-dot {
				border-color: #b8d2f8;
				background: var(--blue);
				color: #ffffff;
			}

			.progress-step.success .progress-dot {
				border-color: #bbe4ca;
				background: var(--green);
				color: #ffffff;
			}

			.button-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem;
			}

			.button,
			.icon-button {
				display: inline-flex;
				min-height: 2.55rem;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				color: var(--text);
				padding: 0.62rem 0.85rem;
				font-weight: 760;
			}

			.button.primary {
				border-color: var(--blue);
				background: var(--blue);
				color: #ffffff;
			}

			.button.primary:hover {
				background: var(--blue-dark);
			}

			.button.danger {
				border-color: #efb5ae;
				color: var(--red);
			}

			.button.ghost {
				background: transparent;
				color: var(--muted);
			}

			.icon-button {
				width: 2.35rem;
				min-height: 2.35rem;
				padding: 0;
			}

			.ops-card {
				display: grid;
				gap: 0.8rem;
			}

			.bot-session {
				display: grid;
				grid-template-columns: 3.4rem minmax(0, 1fr) auto;
				gap: 0.8rem;
				align-items: center;
				border: 1px solid #bbe4ca;
				border-radius: var(--radius);
				background: var(--green-soft);
				padding: 0.75rem;
			}

			.bot-session .bot-icon {
				width: 3rem;
				height: 3rem;
				border-radius: var(--radius);
				background: #d7f2e3;
				color: var(--green);
			}

			.bot-session strong,
			.bot-session span {
				display: block;
			}

			.bot-session span {
				margin-top: 0.16rem;
				color: var(--muted);
				font-size: 0.78rem;
			}

			.metric-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				border: 1px solid var(--line);
				border-radius: var(--radius);
				overflow: hidden;
			}

			.metric {
				min-height: 4.9rem;
				border-left: 1px solid var(--line-soft);
				background: #ffffff;
				padding: 0.75rem;
			}

			.metric:first-child {
				border-left: 0;
			}

			.metric span {
				display: block;
				color: var(--muted);
				font-size: 0.72rem;
				font-weight: 760;
			}

			.metric strong {
				display: block;
				margin-top: 0.42rem;
				overflow-wrap: anywhere;
				font-size: 0.92rem;
				line-height: 1.3;
			}

			.message {
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: var(--surface-soft);
				color: var(--muted);
				padding: 0.75rem 0.85rem;
				font-size: 0.84rem;
				line-height: 1.45;
			}

			.message[data-tone="success"] {
				border-color: #bbe4ca;
				background: var(--green-soft);
				color: var(--green);
			}

			.message[data-tone="warning"] {
				border-color: #f0d593;
				background: var(--amber-soft);
				color: var(--amber);
			}

			.message[data-tone="error"] {
				border-color: #efb5ae;
				background: var(--red-soft);
				color: var(--red);
			}

			.table-panel {
				min-height: 0;
			}

			.table-wrap {
				overflow: auto;
			}

			table {
				width: 100%;
				min-width: 48rem;
				border-collapse: collapse;
				font-size: 0.82rem;
			}

			th,
			td {
				border-bottom: 1px solid var(--line-soft);
				padding: 0.7rem 0.8rem;
				text-align: left;
				vertical-align: middle;
			}

			th {
				color: var(--muted);
				font-size: 0.72rem;
				font-weight: 800;
			}

			td {
				color: #344054;
			}

			.mono {
				font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
			}

			.row-actions {
				display: flex;
				gap: 0.35rem;
			}

			.activity {
				display: grid;
				max-height: 15rem;
				overflow: auto;
			}

			.activity-row {
				display: grid;
				grid-template-columns: 5.2rem minmax(0, 1fr) auto;
				gap: 0.75rem;
				align-items: center;
				border-top: 1px solid var(--line-soft);
				padding: 0.68rem 0.85rem;
				color: var(--muted);
				font-size: 0.78rem;
			}

			.activity-row:first-child {
				border-top: 0;
			}

			.activity-row strong {
				color: var(--text);
				font-weight: 720;
			}

			.diag-section {
				display: grid;
				gap: 0.7rem;
				border-bottom: 1px solid var(--line);
				padding: 0.9rem 0;
			}

			.diag-section:first-child {
				padding-top: 0;
			}

			.diag-section:last-child {
				border-bottom: 0;
			}

			.diag-title {
				display: flex;
				align-items: center;
				gap: 0.55rem;
				font-size: 0.88rem;
				font-weight: 800;
			}

			.diag-list {
				display: grid;
				gap: 0.46rem;
				color: var(--muted);
				font-size: 0.78rem;
			}

			.diag-row {
				display: flex;
				justify-content: space-between;
				gap: 0.65rem;
			}

			.diag-row strong {
				min-width: 0;
				overflow-wrap: anywhere;
				color: var(--text);
				font-weight: 700;
				text-align: right;
			}

			.empty-state {
				padding: 1.2rem;
				color: var(--muted);
				font-size: 0.84rem;
				text-align: center;
			}

			.modal-backdrop {
				position: fixed;
				inset: 0;
				z-index: 30;
				display: none;
				place-items: center;
				background: rgba(18, 26, 39, 0.36);
				padding: 1rem;
			}

			.modal-backdrop.show {
				display: grid;
			}

			.modal {
				display: grid;
				gap: 0.9rem;
				width: min(28rem, 100%);
				border-radius: 12px;
				background: #ffffff;
				padding: 1.1rem;
				box-shadow: 0 28px 90px rgba(18, 26, 39, 0.28);
			}

			.modal h2 {
				font-size: 1.05rem;
			}

			.modal p {
				color: var(--muted);
				font-size: 0.86rem;
				line-height: 1.5;
			}

			.modal-actions {
				display: flex;
				justify-content: flex-end;
				gap: 0.55rem;
			}

			.notice {
				position: fixed;
				left: 50%;
				bottom: 1.1rem;
				z-index: 40;
				transform: translateX(-50%) translateY(0.5rem);
				border-radius: var(--radius);
				background: #111827;
				color: #ffffff;
				padding: 0.7rem 0.9rem;
				font-size: 0.84rem;
				opacity: 0;
				pointer-events: none;
				transition:
					opacity 160ms ease,
					transform 160ms ease;
			}

			.notice.show {
				transform: translateX(-50%);
				opacity: 1;
			}

			.hidden {
				display: none !important;
			}

			@media (max-width: 1180px) {
				body {
					overflow: auto;
				}

				.app {
					grid-template-columns: 1fr;
					height: auto;
					min-height: 100vh;
					padding: 0;
				}

				.rail {
					position: sticky;
					top: 0;
					z-index: 10;
					grid-template-columns: auto 1fr auto;
					grid-template-rows: auto;
					align-items: center;
					border-radius: 0;
				}

				.nav {
					grid-auto-flow: column;
					overflow: auto;
				}

				.nav-label,
				.rail-status {
					display: none;
				}

				.shell {
					border-radius: 0;
					border-left: 0;
					border-right: 0;
				}

				.workspace {
					grid-template-columns: 1fr;
				}

				.diagnostics {
					border-left: 0;
					border-top: 1px solid var(--line);
				}
			}

			@media (max-width: 820px) {
				body {
					overflow: auto;
				}

				.topbar,
				.selector,
				.primary-grid,
				.metric-grid {
					grid-template-columns: 1fr;
				}

				.top-actions {
					justify-content: stretch;
				}

				.status-pill,
				.button,
				.rail-action {
					width: 100%;
				}

				.main {
					padding: 0.85rem;
				}

				.auth-state,
				.bot-session,
				.activity-row {
					grid-template-columns: 1fr;
				}

				.progress {
					grid-template-columns: 1fr;
				}

				.metric {
					border-left: 0;
