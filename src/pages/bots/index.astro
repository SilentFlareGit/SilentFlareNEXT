---
const apiBase =
	import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.silentflare.com";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Telegram Bot Management</title>
		<meta name="description" content="SilentFlare bot operations dashboard" />
		<style>
			:root {
				color-scheme: dark;
				--bg: #05090d;
				--bg-lift: #0b1218;
				--panel: #111922;
				--panel-2: #162230;
				--panel-3: #203247;
				--line: rgba(153, 178, 204, 0.16);
				--line-strong: rgba(153, 178, 204, 0.28);
				--text: #f3f8ff;
				--muted: #9aabbf;
				--muted-2: #718399;
				--blue: #62b4ff;
				--green: #8ee0a6;
				--red: #ff7b7b;
				--shadow: 0 28px 90px rgba(0, 0, 0, 0.34);
			}

			* {
				box-sizing: border-box;
			}

			html {
				min-height: 100%;
				background: var(--bg);
			}

			body {
				margin: 0;
				min-height: 100vh;
				background:
					linear-gradient(135deg, rgba(98, 180, 255, 0.13), transparent 28rem),
					radial-gradient(circle at 78% 14%, rgba(142, 224, 166, 0.08), transparent 22rem),
					var(--bg);
				color: var(--text);
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
					sans-serif;
			}

			button,
			input {
				font: inherit;
			}

			.shell {
				display: grid;
				width: min(100% - 2rem, 1080px);
				min-height: 100vh;
				margin: 0 auto;
				padding: 3rem 0;
				align-content: center;
				gap: 1rem;
			}

			.hero,
			.panel {
				border: 1px solid var(--line);
				border-radius: 8px;
				background: color-mix(in srgb, var(--panel) 94%, transparent);
				box-shadow: var(--shadow);
			}

			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 2rem;
				align-items: start;
				padding: 2rem 2.25rem;
			}

			.hero h1 {
				margin: 0;
				font-size: clamp(2rem, 4vw, 2.75rem);
				font-weight: 760;
				letter-spacing: 0;
				line-height: 1.06;
			}

			.hero p {
				max-width: 48rem;
				margin: 0.9rem 0 0;
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.7;
			}

			.status-pill {
				min-width: 7.25rem;
				border-radius: 6px;
				background: var(--panel-3);
				padding: 0.85rem 1rem;
				color: #d9ecff;
				font-size: 0.86rem;
				font-weight: 760;
				text-align: center;
			}

			.status-pill[data-tone="error"] {
				background: rgba(255, 123, 123, 0.12);
				color: var(--red);
			}

			.flow {
				display: grid;
				grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1fr);
				gap: 1rem;
			}

			.panel {
				min-height: 24rem;
				padding: 1.45rem;
			}

			.panel-title {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.1rem;
			}

			.eyebrow {
				margin: 0;
				color: var(--muted-2);
				font-size: 0.76rem;
				font-weight: 820;
				letter-spacing: 0;
				text-transform: uppercase;
			}

			.step {
				display: inline-grid;
				width: 2rem;
				height: 2rem;
				place-items: center;
				border: 1px solid var(--line);
				border-radius: 6px;
				color: var(--muted);
				font-size: 0.85rem;
				font-weight: 820;
			}

			.bot-list {
				display: grid;
				gap: 0.75rem;
			}

			.bot-card {
				width: 100%;
				border: 1px solid var(--line);
				border-radius: 8px;
				background: var(--bg-lift);
				color: var(--text);
				padding: 1rem;
				text-align: left;
				cursor: pointer;
				transition:
					background 160ms ease,
					border-color 160ms ease,
					transform 160ms ease;
			}

			.bot-card:hover,
			.bot-card[aria-pressed="true"] {
				border-color: rgba(98, 180, 255, 0.52);
				background: var(--panel-2);
				transform: translateY(-1px);
			}

			.bot-card strong {
				display: block;
				font-size: 1rem;
				line-height: 1.35;
			}

			.bot-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				margin-top: 0.75rem;
			}

			.chip {
				border: 1px solid var(--line);
				border-radius: 999px;
				padding: 0.32rem 0.55rem;
				color: var(--muted);
				font-size: 0.74rem;
				font-weight: 760;
			}

			.chip[data-tone="ready"] {
				border-color: rgba(142, 224, 166, 0.28);
				color: var(--green);
			}

			.stage {
				display: grid;
				min-height: 100%;
			}

			.stage-card {
				display: grid;
				align-content: center;
				min-height: 21rem;
				border: 1px solid var(--line);
				border-radius: 8px;
				background: linear-gradient(180deg, rgba(32, 50, 71, 0.4), transparent);
				padding: 2rem;
			}

			.stage-card h2 {
				margin: 0;
				font-size: clamp(1.65rem, 3vw, 2.35rem);
				font-weight: 760;
				letter-spacing: 0;
				line-height: 1.1;
			}

			.stage-card p {
				max-width: 37rem;
				margin: 0.9rem 0 0;
				color: var(--muted);
				line-height: 1.65;
			}

			.auth-form {
				display: grid;
				max-width: 24rem;
				gap: 0.85rem;
				margin-top: 1.35rem;
			}

			.code-input {
				width: 100%;
				border: 1px solid var(--line-strong);
				border-radius: 8px;
				background: #0d141c;
				color: var(--text);
				padding: 1rem 1.05rem;
				font-size: 1.3rem;
				font-weight: 760;
				letter-spacing: 0.12em;
				outline: none;
			}

			.code-input:focus {
				border-color: rgba(98, 180, 255, 0.7);
				box-shadow: 0 0 0 3px rgba(98, 180, 255, 0.1);
			}

			.button {
				display: inline-flex;
				min-height: 2.85rem;
				align-items: center;
				justify-content: center;
				border: 0;
				border-radius: 8px;
				background: var(--panel-3);
				color: var(--text);
				padding: 0.8rem 1.05rem;
				font-weight: 820;
				cursor: pointer;
			}

			.button:hover {
				background: #2a425e;
			}

			.button:disabled {
				cursor: not-allowed;
				opacity: 0.55;
			}

			.button.secondary {
				border: 1px solid var(--line);
				background: transparent;
				color: var(--muted);
			}

			.message {
				margin-top: 1rem;
				border: 1px dashed var(--line);
				border-radius: 8px;
				padding: 0.95rem 1rem;
				color: var(--muted);
				font-size: 0.9rem;
				line-height: 1.5;
			}

			.message[data-tone="error"] {
				border-color: rgba(255, 123, 123, 0.34);
				color: var(--red);
			}

			.message[data-tone="success"] {
				border-color: rgba(142, 224, 166, 0.3);
				color: var(--green);
			}

			.ops-head {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.25rem;
			}

			.ops-head h2 {
				margin: 0.35rem 0 0;
				font-size: 1.65rem;
			}

			.metric-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.7rem;
			}

			.metric {
				min-height: 5.7rem;
				border: 1px solid var(--line);
				border-radius: 8px;
				background: var(--panel-2);
				padding: 0.95rem;
			}

			.metric span {
				color: var(--muted-2);
				font-size: 0.78rem;
				font-weight: 760;
			}

			.metric strong {
				display: block;
				margin-top: 0.55rem;
				overflow-wrap: anywhere;
				font-size: 1.05rem;
				line-height: 1.25;
			}

			.history {
				margin-top: 1rem;
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: 8px;
				background: var(--panel-2);
			}

			.history-row {
				display: grid;
				grid-template-columns: 1fr 6.5rem;
				gap: 0.75rem;
				border-top: 1px solid var(--line);
				padding: 0.82rem 1rem;
				color: var(--muted);
				font-size: 0.86rem;
			}

			.history-row:first-child {
				border-top: 0;
			}

			.history-row strong {
				min-width: 0;
				overflow: hidden;
				color: #d4e2f1;
				font-weight: 760;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.history-row span {
				text-align: right;
			}

			.hidden {
				display: none !important;
			}

			@media (max-width: 820px) {
				.shell {
					width: min(100% - 1rem, 1080px);
					padding: 0.5rem 0 1rem;
					align-content: start;
				}

				.hero,
				.flow,
				.metric-grid {
					grid-template-columns: 1fr;
				}

				.hero,
				.panel,
				.stage-card {
					padding: 1.25rem;
				}

				.panel {
					min-height: auto;
				}

				.status-pill,
				.button {
					width: 100%;
				}

				.ops-head {
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>
		<main class="shell">
			<section class="hero" aria-labelledby="page-title">
				<div>
					<h1 id="page-title">Telegram Bot Management</h1>
					<p>
						Choose a bot first, then unlock that bot with its own verification method.
					</p>
				</div>
				<div id="api-health" class="status-pill">Checking API</div>
			</section>

			<section class="flow" aria-label="Bot authentication and operations">
				<div class="panel">
					<div class="panel-title">
						<p class="eyebrow">Select bot</p>
						<span class="step">1</span>
					</div>
					<div id="bot-list" class="bot-list">
						<button type="button" class="bot-card" disabled>Loading bots</button>
					</div>
				</div>

				<div class="panel stage">
					<div id="select-stage" class="stage-card">
						<p class="eyebrow">Verification</p>
						<h2>Select a bot</h2>
						<p>Each bot has its own login method. Select the bot you want to manage before entering a 2FA code or approving access.</p>
					</div>

					<div id="auth-stage" class="stage-card hidden">
						<p id="auth-method-label" class="eyebrow">2FA verification</p>
						<h2 id="auth-title">Unlock bot</h2>
						<p id="auth-copy">Enter the 6-digit authenticator code for this bot.</p>
						<form id="auth-form" class="auth-form" autocomplete="off">
							<input
								id="auth-code"
								class="code-input"
								name="code"
								inputmode="numeric"
								pattern="[0-9]{6}"
								minlength="6"
								maxlength="6"
								autocomplete="one-time-code"
								placeholder="000000"
								aria-label="Six-digit authentication code"
								required
							/>
							<button id="auth-submit" type="submit" class="button">Verify</button>
						</form>
						<div id="auth-message" class="message">Waiting for verification.</div>
					</div>

					<div id="ops-stage" class="hidden">
						<div class="ops-head">
							<div>
								<p id="selected-bot-purpose" class="eyebrow">Database backup</p>
								<h2 id="selected-bot-name">Ghost database backup bot</h2>
							</div>
							<div class="ops-head">
								<button id="run-backup" type="button" class="button">Run backup</button>
								<button id="logout" type="button" class="button secondary">Lock</button>
							</div>
						</div>

						<div class="metric-grid">
							<div class="metric">
								<span>Timer</span>
								<strong id="backup-timer">Unknown</strong>
							</div>
							<div class="metric">
								<span>Latest backup</span>
								<strong id="backup-latest">Unknown</strong>
							</div>
							<div class="metric">
								<span>Local files</span>
								<strong id="backup-count">0</strong>
							</div>
						</div>

						<div id="backup-message" class="message">Waiting for API status.</div>
						<div id="backup-history" class="history">
							<div class="history-row">
								<strong>No backup history loaded.</strong>
								<span></span>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>

		<script is:inline define:vars={{ apiBase }}>
			const apiHealth = document.getElementById("api-health");
			const botList = document.getElementById("bot-list");
			const selectStage = document.getElementById("select-stage");
			const authStage = document.getElementById("auth-stage");
			const opsStage = document.getElementById("ops-stage");
			const authForm = document.getElementById("auth-form");
			const authCode = document.getElementById("auth-code");
			const authSubmit = document.getElementById("auth-submit");
			const authTitle = document.getElementById("auth-title");
			const authCopy = document.getElementById("auth-copy");
			const authMethodLabel = document.getElementById("auth-method-label");
			const authMessage = document.getElementById("auth-message");
			const logout = document.getElementById("logout");
			const runBackup = document.getElementById("run-backup");
			const selectedBotName = document.getElementById("selected-bot-name");
			const selectedBotPurpose = document.getElementById("selected-bot-purpose");
			const backupTimer = document.getElementById("backup-timer");
			const backupLatest = document.getElementById("backup-latest");
			const backupCount = document.getElementById("backup-count");
			const backupMessage = document.getElementById("backup-message");
			const backupHistory = document.getElementById("backup-history");

			let csrfToken = sessionStorage.getItem("silentflare_bot_csrf") ?? "";
			let bots = [];
			let selectedBot = null;

			function setHealth(message, tone = "neutral") {
				apiHealth.textContent = message;
				apiHealth.dataset.tone = tone;
			}

			function setAuthMessage(message, tone = "neutral") {
				authMessage.textContent = message;
				authMessage.dataset.tone = tone;
			}

			function setBackupMessage(message, tone = "neutral") {
				backupMessage.textContent = message;
				backupMessage.dataset.tone = tone;
			}

			function showStage(stage) {
				selectStage.classList.toggle("hidden", stage !== "select");
				authStage.classList.toggle("hidden", stage !== "auth");
				opsStage.classList.toggle("hidden", stage !== "ops");
			}

			function formatAuthMethod(method) {
				if (method === "totp") return "2FA";
				if (method === "telegram") return "Bot authorization";
				return method;
			}

			function formatSize(value) {
				if (!Number.isFinite(value)) return "0 B";
				if (value < 1024) return `${value} B`;
				if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
				return `${(value / 1024 / 1024).toFixed(1)} MB`;
			}

			async function api(path, options = {}) {
				const headers = {
					Accept: "application/json",
					...(options.body ? { "Content-Type": "application/json" } : {}),
					...(options.csrf ? { "X-CSRF-Token": csrfToken } : {}),
					...(options.headers ?? {}),
				};
				const response = await fetch(`${apiBase}${path}`, {
					...options,
					credentials: "include",
					headers,
				});
				if (response.status === 401 || response.status === 403) {
					if (options.lockOnAuthFailure !== false) showStage(selectedBot ? "auth" : "select");
				}
				if (!response.ok) {
					let detail = `API ${response.status}`;
					try {
						const errorBody = await response.json();
						detail = errorBody.detail ?? detail;
					} catch {
						// Keep the status-based message.
					}
					throw new Error(detail);
				}
				return response.json();
			}

			function selectBot(bot) {
				selectedBot = bot;
				sessionStorage.setItem("silentflare_selected_bot", bot.id);
				for (const item of botList.querySelectorAll(".bot-card")) {
					item.setAttribute("aria-pressed", String(item.dataset.botId === bot.id));
				}
				selectedBotName.textContent = bot.name;
				selectedBotPurpose.textContent = bot.purpose;
				authTitle.textContent = `Unlock ${bot.name}`;
				authMethodLabel.textContent = `${formatAuthMethod(bot.auth_method)} verification`;
				authCopy.textContent =
					bot.auth_method === "totp"
						? "Enter the 6-digit authenticator code assigned to this bot."
						: "Approve the login request from the selected Telegram bot.";
				authCode.value = "";
				setAuthMessage("Waiting for verification.");
				showStage("auth");
				window.setTimeout(() => authCode?.focus(), 0);
			}

			function renderBots() {
				botList.textContent = "";
				for (const bot of bots) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = "bot-card";
					button.dataset.botId = bot.id;
					button.setAttribute("aria-pressed", String(selectedBot?.id === bot.id));
					button.innerHTML = `
						<strong></strong>
						<div class="bot-meta">
							<span class="chip" data-tone="ready"></span>
							<span class="chip"></span>
						</div>
					`;
					button.querySelector("strong").textContent = bot.name;
					const chips = button.querySelectorAll(".chip");
					chips[0].textContent = bot.status;
					chips[1].textContent = formatAuthMethod(bot.auth_method);
					button.addEventListener("click", () => selectBot(bot));
					botList.append(button);
				}
			}

			function renderStatus(status) {
				backupTimer.textContent = status.timer_active ? "Active" : "Inactive";
				backupLatest.textContent = status.latest?.created_at ?? "None";
				backupCount.textContent = String(status.backups.length);
				backupHistory.textContent = "";

				if (status.backups.length === 0) {
					const empty = document.createElement("div");
					empty.className = "history-row";
					const name = document.createElement("strong");
					name.textContent = "No local backups found.";
					empty.append(name, document.createElement("span"));
					backupHistory.append(empty);
					return;
				}

				for (const item of status.backups) {
					const row = document.createElement("div");
					row.className = "history-row";
					const name = document.createElement("strong");
					name.textContent = item.filename;
					const size = document.createElement("span");
					size.textContent = formatSize(item.size);
					row.append(name, size);
					backupHistory.append(row);
				}
			}

			async function loadStatus() {
				if (!selectedBot) return;
				try {
					const status = await api(`/bots/${selectedBot.id}/backup/status`);
					renderStatus(status);
					setBackupMessage(status.message ?? "Backup status loaded.", "success");
				} catch (error) {
					setBackupMessage(`Unable to load backup status: ${error.message}`, "error");
				}
			}

			async function enterOps(bot) {
				selectedBot = bot;
				selectedBotName.textContent = bot.name;
				selectedBotPurpose.textContent = bot.purpose;
				showStage("ops");
				await loadStatus();
			}

			async function boot() {
				try {
					const health = await api("/health", { lockOnAuthFailure: false });
					setHealth(health.ok ? "API online" : "API degraded");
				} catch {
					setHealth("API offline", "error");
				}

				try {
					const list = await api("/bots", { lockOnAuthFailure: false });
					bots = list.bots;
					const remembered = sessionStorage.getItem("silentflare_selected_bot");
					selectedBot = bots.find((bot) => bot.id === remembered) ?? null;
					renderBots();
				} catch (error) {
					botList.textContent = "";
					const item = document.createElement("div");
					item.className = "message";
					item.dataset.tone = "error";
					item.textContent = `Unable to load bots: ${error.message}`;
					botList.append(item);
				}

				try {
					const session = await api("/auth/me", { lockOnAuthFailure: false });
					csrfToken = session.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					await enterOps(session.bot);
				} catch {
					showStage(selectedBot ? "auth" : "select");
				}
			}

			authForm?.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (!selectedBot) return;
				authSubmit.disabled = true;
				authSubmit.textContent = "Verifying";
				try {
					const result = await api("/auth/login", {
						method: "POST",
						body: JSON.stringify({
							bot_id: selectedBot.id,
							method: selectedBot.auth_method,
							code: authCode.value,
						}),
						lockOnAuthFailure: false,
					});
					csrfToken = result.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					setAuthMessage("Verification accepted.", "success");
					await enterOps(result.bot);
				} catch (error) {
					setAuthMessage(`Verification failed: ${error.message}`, "error");
				} finally {
					authSubmit.disabled = false;
					authSubmit.textContent = "Verify";
				}
			});

			logout?.addEventListener("click", async () => {
				try {
					await api("/auth/logout", { method: "POST", csrf: true });
				} catch {
					// Local state still clears if the remote session already expired.
				}
				csrfToken = "";
				sessionStorage.removeItem("silentflare_bot_csrf");
				showStage(selectedBot ? "auth" : "select");
			});

			runBackup?.addEventListener("click", async () => {
				if (!selectedBot) return;
				runBackup.disabled = true;
				runBackup.textContent = "Running";
				setBackupMessage("Backup job started.");
				try {
					const result = await api(`/bots/${selectedBot.id}/backup/run`, {
						method: "POST",
						csrf: true,
					});
					setBackupMessage(result.message ?? "Backup completed.", "success");
					await loadStatus();
				} catch (error) {
					setBackupMessage(`Backup failed: ${error.message}`, "error");
				} finally {
					runBackup.disabled = false;
					runBackup.textContent = "Run backup";
				}
			});

			boot();
		</script>
	</body>
</html>
