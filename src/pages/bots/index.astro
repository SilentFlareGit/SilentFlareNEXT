---
const apiBase =
	import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.silentflare.com";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Telegram Bot Management</title>
		<meta name="description" content="SilentFlare bot operations dashboard" />
		<style>
			:root {
				color-scheme: dark;
				--bg: #070c10;
				--panel: #151c23;
				--panel-strong: #1c2935;
				--panel-soft: #223446;
				--line: rgba(163, 184, 205, 0.14);
				--text: #f4f7fb;
				--muted: #9baabd;
				--accent: #61aef7;
				--danger: #f07979;
				--success: #83d39b;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background:
					radial-gradient(circle at top left, rgba(97, 174, 247, 0.16), transparent 28rem),
					var(--bg);
				color: var(--text);
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
					sans-serif;
			}

			button,
			input {
				font: inherit;
			}

			.shell {
				width: min(100% - 2rem, 980px);
				margin: 0 auto;
				padding: 3.5rem 0;
			}

			.hero,
			.panel {
				border: 1px solid var(--line);
				border-radius: 8px;
				background: var(--panel);
				box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
			}

			.hero {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 2rem;
				padding: 2rem 2.25rem;
			}

			.hero h1 {
				margin: 0 0 0.85rem;
				font-size: clamp(2rem, 4vw, 2.65rem);
				line-height: 1.05;
				letter-spacing: 0;
			}

			.hero p {
				max-width: 45rem;
				margin: 0;
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.75;
			}

			.status-pill {
				flex: none;
				min-width: 7rem;
				border-radius: 6px;
				background: var(--panel-soft);
				padding: 0.85rem 1rem;
				color: #c9d8e8;
				font-size: 0.9rem;
				font-weight: 700;
				text-align: center;
			}

			.status-pill[data-tone="error"] {
				background: rgba(240, 121, 121, 0.14);
				color: var(--danger);
			}

			.workspace {
				display: grid;
				grid-template-columns: 18rem 1fr;
				gap: 1rem;
				margin-top: 1rem;
			}

			.panel {
				padding: 1.35rem;
			}

			.panel-label {
				margin: 0 0 1rem;
				color: var(--muted);
				font-size: 0.78rem;
				font-weight: 800;
				letter-spacing: 0;
				text-transform: uppercase;
			}

			.login-panel {
				max-width: 30rem;
				margin-top: 1rem;
			}

			.form-stack {
				display: grid;
				gap: 0.85rem;
			}

			.field {
				display: grid;
				gap: 0.45rem;
			}

			.field span {
				color: var(--muted);
				font-size: 0.86rem;
				font-weight: 700;
			}

			.field input {
				width: 100%;
				border: 1px solid var(--line);
				border-radius: 6px;
				background: #0f151b;
				color: var(--text);
				padding: 0.82rem 0.9rem;
				outline: none;
			}

			.field input:focus {
				border-color: rgba(97, 174, 247, 0.65);
			}

			.button {
				display: inline-flex;
				min-height: 2.75rem;
				align-items: center;
				justify-content: center;
				border: 0;
				border-radius: 6px;
				background: var(--panel-soft);
				color: var(--text);
				padding: 0.75rem 1rem;
				font-weight: 800;
				cursor: pointer;
			}

			.button:hover {
				background: #2a4055;
			}

			.button:disabled {
				cursor: not-allowed;
				opacity: 0.55;
			}

			.button.secondary {
				background: transparent;
				color: var(--muted);
				border: 1px solid var(--line);
			}

			.bot-list {
				display: grid;
				gap: 0.5rem;
			}

			.bot-button {
				width: 100%;
				border: 0;
				border-radius: 6px;
				background: transparent;
				color: var(--muted);
				padding: 0.85rem 0.95rem;
				text-align: left;
				font-weight: 800;
				cursor: pointer;
			}

			.bot-button[aria-pressed="true"],
			.bot-button:hover {
				background: var(--panel-soft);
				color: var(--text);
			}

			.detail-head {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.3rem;
			}

			.detail-head h2 {
				margin: 0.35rem 0 0;
				font-size: 1.45rem;
				line-height: 1.2;
				letter-spacing: 0;
			}

			.metric-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.65rem;
			}

			.metric {
				min-height: 5.75rem;
				border-radius: 6px;
				background: var(--panel-soft);
				padding: 1rem;
			}

			.metric span {
				color: var(--muted);
				font-size: 0.82rem;
				font-weight: 700;
			}

			.metric strong {
				display: block;
				margin-top: 0.55rem;
				overflow-wrap: anywhere;
				font-size: 1.08rem;
				line-height: 1.25;
			}

			.message {
				margin-top: 1rem;
				border: 1px dashed var(--line);
				border-radius: 6px;
				padding: 1rem;
				color: var(--muted);
				font-size: 0.92rem;
				line-height: 1.55;
			}

			.message[data-tone="error"] {
				border-color: rgba(240, 121, 121, 0.3);
				color: var(--danger);
			}

			.message[data-tone="success"] {
				border-color: rgba(131, 211, 155, 0.3);
				color: var(--success);
			}

			.history {
				margin-top: 1rem;
				overflow: hidden;
				border-radius: 6px;
				background: var(--panel-soft);
			}

			.history-row {
				display: grid;
				grid-template-columns: 1fr 6.5rem;
				gap: 0.75rem;
				border-top: 1px solid var(--line);
				padding: 0.8rem 1rem;
				color: var(--muted);
				font-size: 0.86rem;
			}

			.history-row:first-child {
				border-top: 0;
			}

			.history-row strong {
				min-width: 0;
				overflow: hidden;
				color: #cdd9e7;
				font-weight: 800;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.history-row span {
				text-align: right;
			}

			.hidden {
				display: none !important;
			}

			@media (max-width: 760px) {
				.shell {
					width: min(100% - 1rem, 980px);
					padding: 0.5rem 0 1rem;
				}

				.hero,
				.detail-head {
					flex-direction: column;
				}

				.hero,
				.panel {
					padding: 1.35rem;
				}

				.workspace,
				.metric-grid {
					grid-template-columns: 1fr;
				}

				.status-pill,
				.button {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<main class="shell">
			<section class="hero" aria-labelledby="page-title">
				<div>
					<h1 id="page-title">Telegram Bot Management</h1>
					<p>
						Select a bot, review its backup status, and trigger controlled
						server-side operations through the SilentFlare API.
					</p>
				</div>
				<div id="api-health" class="status-pill">Checking API</div>
			</section>

			<section id="login-panel" class="panel login-panel" aria-labelledby="login-title">
				<p class="panel-label">Login</p>
				<form id="login-form" class="form-stack">
					<label class="field">
						<span>Username</span>
						<input
							id="login-username"
							name="username"
							autocomplete="username"
							required
						/>
					</label>
					<label class="field">
						<span>Password</span>
						<input
							id="login-password"
							name="password"
							type="password"
							autocomplete="current-password"
							required
						/>
					</label>
					<button id="login-submit" type="submit" class="button">Login</button>
				</form>
				<div id="login-message" class="message">Authentication required.</div>
			</section>

			<section id="app-panel" class="workspace hidden" aria-label="Bot operations">
				<div class="panel">
					<div class="detail-head">
						<p class="panel-label">Bots</p>
						<button id="logout" type="button" class="button secondary">Logout</button>
					</div>
					<div id="bot-list" class="bot-list">
						<button type="button" class="bot-button" disabled>Loading bots</button>
					</div>
				</div>

				<div class="panel">
					<div class="detail-head">
						<div>
							<p id="selected-bot-purpose" class="panel-label">Database backup</p>
							<h2 id="selected-bot-name">Ghost database backup bot</h2>
						</div>
						<button id="run-backup" type="button" class="button">Run backup</button>
					</div>

					<div class="metric-grid">
						<div class="metric">
							<span>Timer</span>
							<strong id="backup-timer">Unknown</strong>
						</div>
						<div class="metric">
							<span>Latest backup</span>
							<strong id="backup-latest">Unknown</strong>
						</div>
						<div class="metric">
							<span>Local files</span>
							<strong id="backup-count">0</strong>
						</div>
					</div>

					<div id="backup-message" class="message">Waiting for API status.</div>

					<div id="backup-history" class="history">
						<div class="history-row">
							<strong>No backup history loaded.</strong>
							<span></span>
						</div>
					</div>
				</div>
			</section>
		</main>

		<script is:inline define:vars={{ apiBase }}>
			const apiHealth = document.getElementById("api-health");
			const loginPanel = document.getElementById("login-panel");
			const appPanel = document.getElementById("app-panel");
			const loginForm = document.getElementById("login-form");
			const loginSubmit = document.getElementById("login-submit");
			const loginMessage = document.getElementById("login-message");
			const logout = document.getElementById("logout");
			const botList = document.getElementById("bot-list");
			const runBackup = document.getElementById("run-backup");
			const selectedBotName = document.getElementById("selected-bot-name");
			const selectedBotPurpose = document.getElementById("selected-bot-purpose");
			const backupTimer = document.getElementById("backup-timer");
			const backupLatest = document.getElementById("backup-latest");
			const backupCount = document.getElementById("backup-count");
			const backupMessage = document.getElementById("backup-message");
			const backupHistory = document.getElementById("backup-history");

			let csrfToken = sessionStorage.getItem("silentflare_bot_csrf") ?? "";
			let selectedBotId = "ghost-db-backup";

			function setHealth(message, tone = "neutral") {
				apiHealth.textContent = message;
				apiHealth.dataset.tone = tone;
			}

			function setLoginMessage(message, tone = "neutral") {
				loginMessage.textContent = message;
				loginMessage.dataset.tone = tone;
			}

			function setBackupMessage(message, tone = "neutral") {
				backupMessage.textContent = message;
				backupMessage.dataset.tone = tone;
			}

			function setAuthenticated(isAuthenticated) {
				loginPanel.classList.toggle("hidden", isAuthenticated);
				appPanel.classList.toggle("hidden", !isAuthenticated);
			}

			function formatSize(value) {
				if (!Number.isFinite(value)) return "0 B";
				if (value < 1024) return `${value} B`;
				if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
				return `${(value / 1024 / 1024).toFixed(1)} MB`;
			}

			async function api(path, options = {}) {
				const headers = {
					Accept: "application/json",
					...(options.body ? { "Content-Type": "application/json" } : {}),
					...(options.csrf ? { "X-CSRF-Token": csrfToken } : {}),
					...(options.headers ?? {}),
				};
				const response = await fetch(`${apiBase}${path}`, {
					...options,
					credentials: "include",
					headers,
				});
				if (response.status === 401 || response.status === 403) {
					setAuthenticated(false);
				}
				if (!response.ok) {
					let detail = `API ${response.status}`;
					try {
						const errorBody = await response.json();
						detail = errorBody.detail ?? detail;
					} catch {
						// Keep the status-based message.
					}
					throw new Error(detail);
				}
				return response.json();
			}

			function renderBots(bots) {
				botList.textContent = "";
				for (const bot of bots) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = "bot-button";
					button.textContent = bot.name;
					button.setAttribute("aria-pressed", String(bot.id === selectedBotId));
					button.addEventListener("click", () => {
						selectedBotId = bot.id;
						selectedBotName.textContent = bot.name;
						selectedBotPurpose.textContent = bot.purpose;
						for (const item of botList.querySelectorAll(".bot-button")) {
							item.setAttribute("aria-pressed", String(item === button));
						}
						loadStatus();
					});
					botList.append(button);
				}
			}

			function renderStatus(status) {
				backupTimer.textContent = status.timer_active ? "Active" : "Inactive";
				backupLatest.textContent = status.latest?.created_at ?? "None";
				backupCount.textContent = String(status.backups.length);
				backupHistory.textContent = "";

				if (status.backups.length === 0) {
					const empty = document.createElement("div");
					empty.className = "history-row";
					const name = document.createElement("strong");
					name.textContent = "No local backups found.";
					empty.append(name, document.createElement("span"));
					backupHistory.append(empty);
					return;
				}

				for (const item of status.backups) {
					const row = document.createElement("div");
					row.className = "history-row";
					const name = document.createElement("strong");
					name.textContent = item.filename;
					const size = document.createElement("span");
					size.textContent = formatSize(item.size);
					row.append(name, size);
					backupHistory.append(row);
				}
			}

			async function loadStatus() {
				try {
					const status = await api(`/bots/${selectedBotId}/backup/status`);
					renderStatus(status);
					setBackupMessage(status.message ?? "Backup status loaded.", "success");
				} catch (error) {
					setBackupMessage(`Unable to load backup status: ${error.message}`, "error");
				}
			}

			async function loadApp() {
				const bots = await api("/bots");
				renderBots(bots.bots);
				await loadStatus();
			}

			async function boot() {
				try {
					const health = await api("/health");
					setHealth(health.ok ? "API online" : "API degraded");
				} catch {
					setHealth("API offline", "error");
				}

				try {
					const session = await api("/auth/me");
					csrfToken = session.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					setAuthenticated(true);
					await loadApp();
				} catch {
					setAuthenticated(false);
				}
			}

			loginForm?.addEventListener("submit", async (event) => {
				event.preventDefault();
				loginSubmit.disabled = true;
				loginSubmit.textContent = "Logging in";
				try {
					const form = new FormData(loginForm);
					const result = await api("/auth/login", {
						method: "POST",
						body: JSON.stringify({
							username: String(form.get("username") ?? ""),
							password: String(form.get("password") ?? ""),
						}),
					});
					csrfToken = result.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					setLoginMessage("Login accepted.", "success");
					setAuthenticated(true);
					await loadApp();
				} catch (error) {
					setLoginMessage(`Login failed: ${error.message}`, "error");
				} finally {
					loginSubmit.disabled = false;
					loginSubmit.textContent = "Login";
				}
			});

			logout?.addEventListener("click", async () => {
				try {
					await api("/auth/logout", { method: "POST", csrf: true });
				} catch {
					// Local UI state should still clear if the remote session already expired.
				}
				csrfToken = "";
				sessionStorage.removeItem("silentflare_bot_csrf");
				setAuthenticated(false);
			});

			runBackup?.addEventListener("click", async () => {
				runBackup.disabled = true;
				runBackup.textContent = "Running";
				setBackupMessage("Backup job started.");
				try {
					const result = await api(`/bots/${selectedBotId}/backup/run`, {
						method: "POST",
						csrf: true,
					});
					setBackupMessage(result.message ?? "Backup completed.", "success");
					await loadStatus();
				} catch (error) {
					setBackupMessage(`Backup failed: ${error.message}`, "error");
				} finally {
					runBackup.disabled = false;
					runBackup.textContent = "Run backup";
				}
			});

			boot();
		</script>
	</body>
</html>
