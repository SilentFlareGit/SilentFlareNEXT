		<div id="notice" class="notice" role="status" aria-live="polite"></div>

		<script is:inline define:vars={{ apiBase }}>
			const nodes = {
				apiHealth: document.getElementById("api-health"),
				authCode: document.getElementById("auth-code"),
				authCopy: document.getElementById("auth-copy"),
				authForm: document.getElementById("auth-form"),
				authMessage: document.getElementById("auth-message"),
				authMethodChip: document.getElementById("auth-method-chip"),
				authSubmit: document.getElementById("auth-submit"),
				authTitle: document.getElementById("auth-title"),
				autoRefresh: document.getElementById("auto-refresh"),
				backupCount: document.getElementById("backup-count"),
				backupHistory: document.getElementById("backup-history"),
				backupLatest: document.getElementById("backup-latest"),
				backupMessage: document.getElementById("backup-message"),
				backupTimer: document.getElementById("backup-timer"),
				botList: document.getElementById("bot-list"),
				challengeCountdown: document.getElementById("challenge-countdown"),
				diagApi: document.getElementById("diag-api"),
				diagAuthMethod: document.getElementById("diag-auth-method"),
				diagBot: document.getElementById("diag-bot"),
				diagChallenge: document.getElementById("diag-challenge"),
				diagCsrf: document.getElementById("diag-csrf"),
				diagResponse: document.getElementById("diag-response"),
				diagSession: document.getElementById("diag-session"),
				lastUpdated: document.getElementById("last-updated"),
				logout: document.getElementById("logout"),
				modalBackdrop: document.getElementById("modal-backdrop"),
				modalBody: document.getElementById("modal-body"),
				modalCancel: document.getElementById("modal-cancel"),
				modalConfirm: document.getElementById("modal-confirm"),
				modalTitle: document.getElementById("modal-title"),
				notice: document.getElementById("notice"),
				progressGrant: document.getElementById("progress-grant"),
				progressRequest: document.getElementById("progress-request"),
				progressWait: document.getElementById("progress-wait"),
				railApi: document.getElementById("rail-api"),
				railLock: document.getElementById("rail-lock"),
				railSession: document.getElementById("rail-session"),
				refreshAll: document.getElementById("refresh-all"),
				refreshStatus: document.getElementById("refresh-status"),
				runBackup: document.getElementById("run-backup"),
				selectedBotName: document.getElementById("selected-bot-name"),
				selectedBotPurpose: document.getElementById("selected-bot-purpose"),
				sessionState: document.getElementById("session-state"),
				telegramCancel: document.getElementById("telegram-cancel"),
				telegramResend: document.getElementById("telegram-resend"),
				telegramStart: document.getElementById("telegram-start"),
				telegramTest: document.getElementById("telegram-test"),
			};

			let csrfToken = sessionStorage.getItem("silentflare_bot_csrf") ?? "";
			let bots = [];
			let selectedBot = null;
			let activeChallenge = null;
			let challengeExpiresAt = null;
			let telegramPoll = null;
			let countdownTimer = null;
			let statusTimer = null;
			let modalHandler = null;
			let activity = [];
			let apiOnline = false;

			function icon(name) {
				return `<svg class="icon"><use href="#icon-${name}"></use></svg>`;
			}

			function formatAuthMethod(method) {
				if (method === "totp") return "2FA";
				if (method === "telegram") return "Telegram";
				return method || "Unknown";
			}

			function formatSize(value) {
				if (!Number.isFinite(value)) return "0 B";
				if (value < 1024) return `${value} B`;
				if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
				return `${(value / 1024 / 1024).toFixed(1)} MB`;
			}

			function formatTime(date = new Date()) {
				return date.toLocaleTimeString([], {
					hour: "2-digit",
					minute: "2-digit",
					second: "2-digit",
				});
			}

			function shortSha(value) {
				if (!value) return "Unavailable";
				return `${value.slice(0, 10)}...${value.slice(-8)}`;
			}

			function setMessage(node, message, tone = "neutral") {
				node.textContent = message;
				node.dataset.tone = tone;
			}

			function setApiState(message, tone = "neutral") {
				nodes.apiHealth.textContent = message;
				nodes.apiHealth.dataset.tone = tone;
				nodes.railApi.textContent = message;
				nodes.diagApi.textContent = message;
			}

			function setProgress(state) {
				for (const item of [nodes.progressRequest, nodes.progressWait, nodes.progressGrant]) {
					item.classList.remove("active", "success");
				}
				if (state === "idle") {
					nodes.challengeCountdown.textContent = selectedBot ? "Ready to request" : "Waiting for selection";
				}
				if (state === "pending") {
					nodes.progressRequest.classList.add("success");
					nodes.progressWait.classList.add("active");
				}
				if (state === "approved") {
					nodes.progressRequest.classList.add("success");
					nodes.progressWait.classList.add("success");
					nodes.progressGrant.classList.add("success");
					nodes.challengeCountdown.textContent = "Approved";
				}
			}

			function toast(message) {
				nodes.notice.textContent = message;
				nodes.notice.classList.add("show");
				window.setTimeout(() => nodes.notice.classList.remove("show"), 2600);
			}

			function addActivity(label, detail = "", tone = "neutral") {
				activity.unshift({
					detail,
					label,
					time: formatTime(),
					tone,
				});
				activity = activity.slice(0, 30);
				renderActivity();
			}

			function renderActivity() {
				const target = document.getElementById("activity");
				target.textContent = "";
				if (activity.length === 0) {
					const empty = document.createElement("div");
					empty.className = "empty-state";
					empty.textContent = "No activity yet.";
					target.append(empty);
					return;
				}
				for (const item of activity) {
					const row = document.createElement("div");
					row.className = "activity-row";
					const time = document.createElement("span");
					time.textContent = item.time;
					const label = document.createElement("strong");
					label.textContent = item.label;
					const detail = document.createElement("span");
					detail.textContent = item.detail;
					const chip = document.createElement("span");
					chip.className = "chip";
					if (item.tone === "success") chip.dataset.tone = "success";
					chip.textContent = item.tone;
					row.append(time, label, chip);
					if (item.detail) row.title = item.detail;
					target.append(row);
				}
			}

			function showModal(title, body, confirmText, onConfirm) {
				nodes.modalTitle.textContent = title;
				nodes.modalBody.textContent = body;
				nodes.modalConfirm.textContent = confirmText;
				modalHandler = onConfirm;
				nodes.modalBackdrop.classList.add("show");
			}

			function closeModal() {
				nodes.modalBackdrop.classList.remove("show");
				modalHandler = null;
			}

			async function api(path, options = {}) {
				const started = performance.now();
				const headers = {
					Accept: "application/json",
					...(options.body ? { "Content-Type": "application/json" } : {}),
					...(options.csrf ? { "X-CSRF-Token": csrfToken } : {}),
					...(options.headers ?? {}),
				};
				const response = await fetch(`${apiBase}${path}`, {
					...options,
					credentials: "include",
					headers,
				});
				nodes.diagResponse.textContent = `${Math.max(1, Math.round(performance.now() - started))}ms`;
				if (response.status === 401 || response.status === 403) {
					setSessionState(false);
				}
				if (!response.ok) {
					let detail = `API ${response.status}`;
					try {
						const body = await response.json();
						detail = body.detail ?? detail;
					} catch {
						// Keep status-based detail.
					}
					throw new Error(detail);
				}
				return response.json();
			}

			function setSessionState(authenticated, bot = selectedBot) {
				nodes.sessionState.textContent = authenticated ? "Authorized" : "Locked";
				nodes.sessionState.dataset.tone = authenticated ? "neutral" : "warning";
				nodes.diagSession.textContent = authenticated ? "Bot-scoped session" : "Locked";
				nodes.diagBot.textContent = bot?.id ?? "None";
				nodes.diagCsrf.textContent = authenticated && csrfToken ? "Loaded" : "Not loaded";
				nodes.railSession.textContent = authenticated ? "Session active" : "Session locked";
				nodes.runBackup.disabled = !authenticated;
				nodes.telegramTest.disabled = !authenticated;
				nodes.logout.disabled = !authenticated;
				nodes.railLock.disabled = !authenticated;
				nodes.refreshStatus.disabled = !authenticated;
				nodes.autoRefresh.textContent = authenticated ? "Auto refresh: 30s" : "Auto refresh: paused";
				if (authenticated) startStatusAutoRefresh();
				else stopStatusAutoRefresh();
			}

			function stopTelegramPolling() {
				if (telegramPoll) window.clearInterval(telegramPoll);
				if (countdownTimer) window.clearInterval(countdownTimer);
				telegramPoll = null;
				countdownTimer = null;
				activeChallenge = null;
				challengeExpiresAt = null;
				nodes.diagChallenge.textContent = "None";
				nodes.telegramCancel.disabled = true;
				nodes.telegramResend.disabled = !selectedBot;
				nodes.telegramStart.disabled = !selectedBot;
			}

			function startStatusAutoRefresh() {
				if (statusTimer) return;
				statusTimer = window.setInterval(() => {
					if (document.visibilityState !== "hidden") loadStatus({ quiet: true });
				}, 30000);
			}

			function stopStatusAutoRefresh() {
				if (statusTimer) window.clearInterval(statusTimer);
				statusTimer = null;
			}

			function updateCountdown() {
				if (!challengeExpiresAt) return;
				const remaining = Math.max(0, Math.round((challengeExpiresAt.getTime() - Date.now()) / 1000));
				const minutes = Math.floor(remaining / 60);
				const seconds = String(remaining % 60).padStart(2, "0");
				nodes.challengeCountdown.textContent =
					remaining > 0 ? `Waiting for approval (${minutes}:${seconds})` : "Login request expired";
				if (remaining <= 0) {
					stopTelegramPolling();
					setProgress("idle");
					setMessage(nodes.authMessage, "Login request expired. Send a new approval request.", "warning");
					addActivity("Approval request expired", selectedBot?.id ?? "", "warning");
				}
			}

			function selectBot(bot) {
				selectedBot = bot;
				sessionStorage.setItem("silentflare_selected_bot", bot.id);
				nodes.selectedBotName.textContent = bot.name;
				nodes.selectedBotPurpose.textContent = `Bot ID: ${bot.id}`;
				nodes.authMethodChip.textContent = `${formatAuthMethod(bot.auth_method)} authorization`;
				nodes.diagAuthMethod.textContent = bot.auth_method;
				nodes.diagBot.textContent = bot.id;
				nodes.authTitle.textContent = bot.auth_method === "telegram" ? "Ready for Owner approval" : "Ready for 2FA";
				nodes.authCopy.textContent =
					bot.auth_method === "telegram"
						? "Send a one-time login request to the fixed Owner account, then approve it in Telegram."
						: "Enter the six-digit authenticator code assigned to this bot.";
				nodes.authForm.classList.toggle("hidden", bot.auth_method !== "totp");
				nodes.telegramStart.classList.toggle("hidden", bot.auth_method !== "telegram");
				nodes.telegramResend.classList.toggle("hidden", bot.auth_method !== "telegram");
				nodes.telegramCancel.classList.toggle("hidden", bot.auth_method !== "telegram");
				nodes.telegramStart.disabled = false;
				nodes.telegramResend.disabled = false;
				nodes.telegramCancel.disabled = true;
				setProgress("idle");
				setSessionState(false, bot);
				setMessage(nodes.authMessage, "Waiting for Owner-approved verification.");
				stopTelegramPolling();
				renderBots();
				addActivity("Bot selected", bot.id, "neutral");
			}

			function renderBots() {
				nodes.botList.textContent = "";
				if (bots.length === 0) {
					const empty = document.createElement("div");
					empty.className = "message";
					empty.textContent = "No bots returned by API.";
					nodes.botList.append(empty);
					return;
				}
				for (const bot of bots) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = "bot-card";
					button.dataset.botId = bot.id;
					button.setAttribute("aria-pressed", String(selectedBot?.id === bot.id));

					const iconWrap = document.createElement("span");
					iconWrap.className = "bot-icon";
					iconWrap.innerHTML = icon("bot");

					const copy = document.createElement("span");
					const name = document.createElement("strong");
					name.textContent = bot.id;
					const purpose = document.createElement("small");
					purpose.textContent = bot.purpose;
					copy.append(name, purpose);

					const status = document.createElement("span");
					status.className = "chip";
					if (bot.status === "active") status.dataset.tone = "success";
					status.textContent = bot.status;

					button.append(iconWrap, copy, status);
					button.addEventListener("click", () => selectBot(bot));
					nodes.botList.append(button);
				}
			}

			function renderStatus(status) {
				nodes.backupTimer.textContent = status.timer_active ? "Active" : "Inactive";
				nodes.backupLatest.textContent = status.latest?.created_at ?? "None";
				nodes.backupCount.textContent = `${status.backups.length} files`;
				nodes.backupHistory.textContent = "";

				if (status.backups.length === 0) {
					const row = document.createElement("tr");
					const cell = document.createElement("td");
					cell.colSpan = 6;
					const empty = document.createElement("div");
					empty.className = "empty-state";
					empty.textContent = "No local backups found.";
					cell.append(empty);
					row.append(cell);
					nodes.backupHistory.append(row);
					return;
				}

				for (const item of status.backups) {
					const row = document.createElement("tr");
					const filename = document.createElement("td");
					filename.className = "mono";
					filename.textContent = item.filename;
					const created = document.createElement("td");
					created.textContent = item.created_at;
					const size = document.createElement("td");
					size.textContent = formatSize(item.size);
					const sha = document.createElement("td");
					sha.className = "mono";
					sha.textContent = shortSha(item.sha256);
					const result = document.createElement("td");
					const chip = document.createElement("span");
					chip.className = "chip";
					chip.dataset.tone = "success";
					chip.textContent = "Success";
					result.append(chip);
					const actions = document.createElement("td");
					const rowActions = document.createElement("div");
					rowActions.className = "row-actions";
					const copyName = document.createElement("button");
					copyName.type = "button";
					copyName.className = "icon-button";
					copyName.title = "Copy filename";
					copyName.innerHTML = icon("copy");
					copyName.addEventListener("click", () => copyText(item.filename, "Filename copied."));
					const copySha = document.createElement("button");
					copySha.type = "button";
					copySha.className = "icon-button";
					copySha.title = "Copy SHA256";
					copySha.innerHTML = icon("info");
					copySha.addEventListener("click", () => copyText(item.sha256, "SHA256 copied."));
					rowActions.append(copyName, copySha);
					actions.append(rowActions);
					row.append(filename, created, size, sha, result, actions);
					nodes.backupHistory.append(row);
				}
			}

			async function copyText(text, successMessage) {
				try {
					await navigator.clipboard.writeText(text);
					toast(successMessage);
				} catch {
					toast(text);
				}
			}

			async function loadStatus(options = {}) {
				if (!selectedBot) return;
				try {
					const status = await api(`/bots/${selectedBot.id}/backup/status`);
					renderStatus(status);
					setMessage(nodes.backupMessage, status.message ?? "Backup status loaded.", "success");
					nodes.lastUpdated.textContent = `Last updated: ${formatTime()}`;
					if (!options.quiet) addActivity("Backup status loaded", selectedBot.id, "success");
				} catch (error) {
					setMessage(nodes.backupMessage, `Unable to load backup status: ${error.message}`, "error");
					if (!options.quiet) addActivity("Backup status failed", error.message, "error");
				}
			}

			async function enterOps(bot) {
				stopTelegramPolling();
				selectedBot = bot;
				nodes.selectedBotName.textContent = bot.name;
				nodes.selectedBotPurpose.textContent = `Bot ID: ${bot.id}`;
				nodes.diagBot.textContent = bot.id;
				setSessionState(true, bot);
				setProgress("approved");
				setMessage(nodes.authMessage, "Telegram authorization approved. Session is bot-scoped.", "success");
				addActivity("Session started", bot.id, "success");
				await loadStatus();
			}

			async function checkTelegramChallenge() {
				if (!selectedBot || !activeChallenge) return;
				try {
					const result = await api(
						`/auth/telegram/status/${activeChallenge}?bot_id=${encodeURIComponent(selectedBot.id)}`,
						{ lockOnAuthFailure: false },
					);
					if (result.status !== "approved") return;
					csrfToken = result.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					await enterOps(result.bot);
				} catch (error) {
					stopTelegramPolling();
					setProgress("idle");
					setMessage(nodes.authMessage, `Authorization failed: ${error.message}`, "error");
					addActivity("Authorization failed", error.message, "error");
				}
			}

			async function startTelegramAuthorization() {
				if (!selectedBot) return;
				stopTelegramPolling();
				nodes.telegramStart.disabled = true;
				nodes.telegramResend.disabled = true;
				nodes.telegramCancel.disabled = false;
				try {
					const result = await api("/auth/telegram/start", {
						method: "POST",
						body: JSON.stringify({ bot_id: selectedBot.id }),
						lockOnAuthFailure: false,
					});
					activeChallenge = result.challenge_id;
					challengeExpiresAt = new Date(result.expires_at);
					nodes.diagChallenge.textContent = "Pending";
					setProgress("pending");
					setMessage(nodes.authMessage, "Approval request sent to Telegram. Confirm from the Owner account.");
					addActivity("Approval request sent", selectedBot.id, "pending");
					updateCountdown();
					countdownTimer = window.setInterval(updateCountdown, 1000);
					telegramPoll = window.setInterval(checkTelegramChallenge, 1800);
					await checkTelegramChallenge();
				} catch (error) {
					stopTelegramPolling();
					setProgress("idle");
					setMessage(nodes.authMessage, `Unable to send approval request: ${error.message}`, "error");
					addActivity("Approval request failed", error.message, "error");
				}
			}

			async function cancelTelegramAuthorization() {
				if (!selectedBot || !activeChallenge) {
					stopTelegramPolling();
					setProgress("idle");
					return;
				}
				const challengeId = activeChallenge;
				try {
					await api("/auth/telegram/cancel", {
						method: "POST",
						body: JSON.stringify({
							bot_id: selectedBot.id,
							challenge_id: challengeId,
						}),
						lockOnAuthFailure: false,
					});
					addActivity("Approval request cancelled", selectedBot.id, "neutral");
				} catch (error) {
					addActivity("Cancel request failed", error.message, "warning");
				}
				stopTelegramPolling();
				setProgress("idle");
				setMessage(nodes.authMessage, "Approval request cancelled. Send a new request when ready.", "warning");
			}

			async function checkHealth() {
				try {
					const health = await api("/health", { lockOnAuthFailure: false });
					apiOnline = Boolean(health.ok);
					setApiState(apiOnline ? "API online" : "API degraded", apiOnline ? "neutral" : "warning");
				} catch {
					apiOnline = false;
					setApiState("API offline", "error");
				}
			}

			async function loadBots() {
				try {
					const list = await api("/bots", { lockOnAuthFailure: false });
					bots = list.bots;
					const remembered = sessionStorage.getItem("silentflare_selected_bot");
					selectedBot = bots.find((bot) => bot.id === remembered) ?? bots[0] ?? null;
					renderBots();
					if (selectedBot) selectBot(selectedBot);
				} catch (error) {
					nodes.botList.textContent = "";
					const item = document.createElement("div");
					item.className = "message";
					item.dataset.tone = "error";
					item.textContent = `Unable to load bots: ${error.message}`;
					nodes.botList.append(item);
					addActivity("Bot list failed", error.message, "error");
				}
			}

			async function restoreSession() {
				try {
					const session = await api("/auth/me", { lockOnAuthFailure: false });
					csrfToken = session.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					await enterOps(session.bot);
				} catch {
					setSessionState(false);
				}
			}

			async function boot() {
				renderActivity();
				await checkHealth();
				await loadBots();
				await restoreSession();
			}

			nodes.authForm?.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (!selectedBot || selectedBot.auth_method !== "totp") return;
				nodes.authSubmit.disabled = true;
				nodes.authSubmit.textContent = "Verifying";
				try {
					const result = await api("/auth/login", {
						method: "POST",
						body: JSON.stringify({
							bot_id: selectedBot.id,
							code: nodes.authCode.value,
							method: selectedBot.auth_method,
						}),
						lockOnAuthFailure: false,
					});
					csrfToken = result.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					await enterOps(result.bot);
				} catch (error) {
					setMessage(nodes.authMessage, `Verification failed: ${error.message}`, "error");
					addActivity("2FA verification failed", error.message, "error");
				} finally {
					nodes.authSubmit.disabled = false;
					nodes.authSubmit.textContent = "Verify 2FA";
				}
			});

			nodes.telegramStart.addEventListener("click", startTelegramAuthorization);
			nodes.telegramResend.addEventListener("click", startTelegramAuthorization);
			nodes.telegramCancel.addEventListener("click", cancelTelegramAuthorization);

			async function logout() {
				try {
					await api("/auth/logout", { method: "POST", csrf: true });
				} catch {
					// Local state still clears if the remote session already expired.
				}
				csrfToken = "";
				sessionStorage.removeItem("silentflare_bot_csrf");
				setSessionState(false);
				stopTelegramPolling();
				setProgress("idle");
				setMessage(nodes.authMessage, "Session locked. Send a new approval request to continue.", "warning");
				addActivity("Session locked", selectedBot?.id ?? "", "neutral");
			}

			nodes.logout.addEventListener("click", logout);
			nodes.railLock.addEventListener("click", logout);

			nodes.runBackup.addEventListener("click", () => {
				if (!selectedBot) return;
				showModal(
					"Run Ghost database backup",
					"This starts the production backup script on FNS1 for the selected bot. Continue only if you intended to create a new Ghost DB backup now.",
					"Run backup",
					async () => {
						closeModal();
						nodes.runBackup.disabled = true;
						setMessage(nodes.backupMessage, "Backup job started.");
						addActivity("Backup started", selectedBot.id, "pending");
						try {
							const result = await api(`/bots/${selectedBot.id}/backup/run`, {
								method: "POST",
								csrf: true,
							});
							setMessage(nodes.backupMessage, result.message ?? "Backup completed.", "success");
							addActivity("Backup completed", result.latest?.filename ?? selectedBot.id, "success");
							await loadStatus({ quiet: true });
						} catch (error) {
							setMessage(nodes.backupMessage, `Backup failed: ${error.message}`, "error");
							addActivity("Backup failed", error.message, "error");
						} finally {
							nodes.runBackup.disabled = false;
						}
					},
				);
			});

			nodes.telegramTest.addEventListener("click", async () => {
				if (!selectedBot) return;
				nodes.telegramTest.disabled = true;
				try {
					const result = await api(`/bots/${selectedBot.id}/telegram/test`, {
						method: "POST",
						csrf: true,
					});
					setMessage(nodes.backupMessage, result.message ?? "Telegram test notification sent.", "success");
					addActivity("Telegram test sent", selectedBot.id, "success");
				} catch (error) {
					setMessage(nodes.backupMessage, `Telegram test failed: ${error.message}`, "error");
					addActivity("Telegram test failed", error.message, "error");
				} finally {
					nodes.telegramTest.disabled = false;
				}
			});

			nodes.refreshStatus.addEventListener("click", () => loadStatus());
			nodes.refreshAll.addEventListener("click", async () => {
				await checkHealth();
				await restoreSession();
				if (csrfToken) await loadStatus();
				toast("Refreshed.");
			});

			document.getElementById("clear-activity").addEventListener("click", () => {
				activity = [];
				renderActivity();
			});

			nodes.modalCancel.addEventListener("click", closeModal);
			nodes.modalBackdrop.addEventListener("click", (event) => {
				if (event.target === nodes.modalBackdrop) closeModal();
			});
			nodes.modalConfirm.addEventListener("click", () => {
				if (modalHandler) modalHandler();
				else closeModal();
			});

			for (const button of document.querySelectorAll("[data-scroll-target]")) {
				button.addEventListener("click", () => {
					for (const item of document.querySelectorAll("[data-scroll-target]")) {
						item.classList.toggle("active", item === button);
					}
					document.getElementById(button.dataset.scrollTarget)?.scrollIntoView({
						behavior: "smooth",
						block: "start",
					});
				});
			}

			boot();
		</script>
	</body>
</html>
