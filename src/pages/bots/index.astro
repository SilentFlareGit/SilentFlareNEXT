---
const apiBase =
	import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.silentflare.com";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Telegram Bot Management</title>
		<meta name="description" content="SilentFlare bot operations dashboard" />
		<style>
			:root {
				color-scheme: dark;
				--bg: #070b0f;
				--panel: #111820;
				--panel-soft: #172332;
				--panel-raised: #1d2b3c;
				--line: rgba(164, 187, 213, 0.16);
				--line-strong: rgba(164, 187, 213, 0.28);
				--text: #f5f8fb;
				--muted: #a4b1c0;
				--subtle: #6f8194;
				--blue: #69b7ff;
				--cyan: #7de3ff;
				--green: #8fe3ac;
				--red: #ff7c7c;
				--radius: 8px;
				--shadow: 0 26px 90px rgba(0, 0, 0, 0.38);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background:
					linear-gradient(135deg, rgba(105, 183, 255, 0.18), transparent 32rem),
					radial-gradient(circle at 84% 12%, rgba(125, 227, 255, 0.11), transparent 22rem),
					radial-gradient(circle at 18% 86%, rgba(143, 227, 172, 0.08), transparent 28rem),
					var(--bg);
				color: var(--text);
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
					sans-serif;
			}

			button,
			input {
				font: inherit;
			}

			.shell {
				display: grid;
				width: min(100% - 2rem, 1180px);
				min-height: 100vh;
				margin: 0 auto;
				padding: 2rem 0;
				place-items: center;
			}

			.console {
				width: 100%;
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: rgba(17, 24, 32, 0.94);
				box-shadow: var(--shadow);
			}

			.topbar {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 1.5rem;
				align-items: center;
				border-bottom: 1px solid var(--line);
				background: linear-gradient(180deg, rgba(29, 43, 60, 0.76), rgba(17, 24, 32, 0.7));
				padding: 1.25rem 1.4rem;
			}

			.brand {
				display: flex;
				min-width: 0;
				align-items: center;
				gap: 0.9rem;
			}

			.brand-mark {
				display: grid;
				width: 2.7rem;
				height: 2.7rem;
				flex: none;
				place-items: center;
				border: 1px solid rgba(105, 183, 255, 0.32);
				border-radius: 8px;
				background: linear-gradient(135deg, rgba(105, 183, 255, 0.24), rgba(125, 227, 255, 0.08));
				color: var(--blue);
				font-weight: 860;
			}

			h1,
			h2,
			p {
				margin: 0;
			}

			h1 {
				font-size: clamp(1.45rem, 3vw, 2rem);
				font-weight: 780;
				letter-spacing: 0;
				line-height: 1.15;
			}

			.topbar p {
				margin-top: 0.28rem;
				color: var(--muted);
				font-size: 0.92rem;
				line-height: 1.45;
			}

			.status-pill {
				display: inline-flex;
				min-height: 2.4rem;
				align-items: center;
				justify-content: center;
				border: 1px solid rgba(105, 183, 255, 0.22);
				border-radius: 999px;
				background: rgba(105, 183, 255, 0.12);
				color: #d8ecff;
				padding: 0.58rem 0.9rem;
				font-size: 0.82rem;
				font-weight: 780;
				white-space: nowrap;
			}

			.status-pill::before {
				width: 0.46rem;
				height: 0.46rem;
				margin-right: 0.48rem;
				border-radius: 999px;
				background: var(--green);
				content: "";
				box-shadow: 0 0 0 4px rgba(143, 227, 172, 0.13);
			}

			.status-pill[data-tone="error"] {
				border-color: rgba(255, 124, 124, 0.28);
				background: rgba(255, 124, 124, 0.1);
				color: var(--red);
			}

			.status-pill[data-tone="error"]::before {
				background: var(--red);
				box-shadow: 0 0 0 4px rgba(255, 124, 124, 0.12);
			}

			.workspace {
				display: grid;
				grid-template-columns: 21rem minmax(0, 1fr);
				min-height: 34rem;
			}

			.sidebar {
				border-right: 1px solid var(--line);
				background: rgba(10, 15, 21, 0.34);
				padding: 1.25rem;
			}

			.main {
				padding: 1.25rem;
			}

			.section-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.label {
				color: var(--subtle);
				font-size: 0.73rem;
				font-weight: 840;
				letter-spacing: 0;
				text-transform: uppercase;
			}

			.step {
				display: inline-grid;
				width: 1.85rem;
				height: 1.85rem;
				place-items: center;
				border: 1px solid var(--line);
				border-radius: 999px;
				color: var(--muted);
				font-size: 0.78rem;
				font-weight: 820;
			}

			.bot-list {
				display: grid;
				gap: 0.7rem;
			}

			.bot-card {
				width: 100%;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: rgba(23, 35, 50, 0.52);
				color: var(--text);
				padding: 0.95rem;
				text-align: left;
				cursor: pointer;
				transition:
					background 160ms ease,
					border-color 160ms ease,
					transform 160ms ease;
			}

			.bot-card:hover,
			.bot-card[aria-pressed="true"] {
				border-color: rgba(105, 183, 255, 0.55);
				background: rgba(29, 43, 60, 0.95);
				transform: translateY(-1px);
			}

			.bot-card strong {
				display: block;
				font-size: 0.98rem;
				font-weight: 780;
				line-height: 1.35;
			}

			.bot-card small {
				display: block;
				margin-top: 0.25rem;
				color: var(--muted);
				font-size: 0.82rem;
				line-height: 1.4;
			}

			.bot-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.78rem;
			}

			.chip {
				border: 1px solid var(--line);
				border-radius: 999px;
				padding: 0.32rem 0.55rem;
				color: var(--muted);
				font-size: 0.72rem;
				font-weight: 760;
			}

			.chip[data-tone="ready"] {
				border-color: rgba(143, 227, 172, 0.28);
				color: var(--green);
			}

			.stage {
				display: grid;
				min-height: 100%;
				align-content: stretch;
			}

			.stage-card,
			.ops-card {
				min-height: 100%;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background:
					linear-gradient(180deg, rgba(29, 43, 60, 0.62), rgba(17, 24, 32, 0.72)),
					var(--panel);
			}

			.stage-card {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 12rem;
				gap: 2rem;
				align-items: center;
				padding: clamp(1.4rem, 4vw, 2.5rem);
			}

			.stage-card h2,
			.ops-head h2 {
				font-size: clamp(1.7rem, 4vw, 2.45rem);
				font-weight: 780;
				letter-spacing: 0;
				line-height: 1.08;
			}

			.stage-card p {
				max-width: 39rem;
				margin-top: 0.85rem;
				color: var(--muted);
				line-height: 1.65;
			}

			.visual-token {
				display: grid;
				width: 12rem;
				height: 12rem;
				place-items: center;
				border: 1px solid rgba(105, 183, 255, 0.18);
				border-radius: 8px;
				background:
					linear-gradient(135deg, rgba(105, 183, 255, 0.18), rgba(125, 227, 255, 0.04)),
					radial-gradient(circle at center, rgba(105, 183, 255, 0.2), transparent 62%);
				color: rgba(216, 236, 255, 0.88);
				font-size: 3.2rem;
				font-weight: 860;
			}

			.telegram-auth,
			.auth-form {
				display: grid;
				max-width: 25rem;
				gap: 0.85rem;
				margin-top: 1.35rem;
			}

			.code-input {
				width: 100%;
				border: 1px solid var(--line-strong);
				border-radius: var(--radius);
				background: rgba(7, 11, 15, 0.72);
				color: var(--text);
				padding: 1rem;
				font-size: 1.25rem;
				font-weight: 760;
				letter-spacing: 0.12em;
				outline: none;
			}

			.code-input:focus {
				border-color: rgba(105, 183, 255, 0.72);
				box-shadow: 0 0 0 3px rgba(105, 183, 255, 0.11);
			}

			.button {
				display: inline-flex;
				min-height: 2.85rem;
				align-items: center;
				justify-content: center;
				border: 1px solid rgba(105, 183, 255, 0.22);
				border-radius: var(--radius);
				background: linear-gradient(180deg, rgba(105, 183, 255, 0.24), rgba(105, 183, 255, 0.12));
				color: var(--text);
				padding: 0.78rem 1rem;
				font-weight: 820;
				cursor: pointer;
			}

			.button:hover {
				border-color: rgba(105, 183, 255, 0.45);
				background: linear-gradient(180deg, rgba(105, 183, 255, 0.32), rgba(105, 183, 255, 0.16));
			}

			.button:disabled {
				cursor: wait;
				opacity: 0.62;
			}

			.button.secondary {
				border-color: var(--line);
				background: transparent;
				color: var(--muted);
			}

			.message {
				max-width: 40rem;
				margin-top: 1rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: rgba(7, 11, 15, 0.42);
				padding: 0.9rem 1rem;
				color: var(--muted);
				font-size: 0.9rem;
				line-height: 1.5;
			}

			.message[data-tone="error"] {
				border-color: rgba(255, 124, 124, 0.34);
				color: var(--red);
			}

			.message[data-tone="success"] {
				border-color: rgba(143, 227, 172, 0.3);
				color: var(--green);
			}

			.ops-card {
				padding: 1.25rem;
			}

			.ops-head {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.action-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}

			.metric-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.75rem;
			}

			.metric {
				min-height: 5.85rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: rgba(23, 35, 50, 0.76);
				padding: 0.95rem;
			}

			.metric span {
				color: var(--subtle);
				font-size: 0.76rem;
				font-weight: 780;
			}

			.metric strong {
				display: block;
				margin-top: 0.56rem;
				overflow-wrap: anywhere;
				font-size: 1.05rem;
				line-height: 1.25;
			}

			.history {
				margin-top: 1rem;
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: rgba(10, 15, 21, 0.44);
			}

			.history-row {
				display: grid;
				grid-template-columns: 1fr 6.5rem;
				gap: 0.75rem;
				border-top: 1px solid var(--line);
				padding: 0.8rem 1rem;
				color: var(--muted);
				font-size: 0.85rem;
			}

			.history-row:first-child {
				border-top: 0;
			}

			.history-row strong {
				min-width: 0;
				overflow: hidden;
				color: #d6e3f0;
				font-weight: 760;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.history-row span {
				text-align: right;
			}

			.hidden {
				display: none !important;
			}

			@media (max-width: 860px) {
				.shell {
					width: min(100% - 1rem, 1180px);
					padding: 0.5rem 0 1rem;
					place-items: start center;
				}

				.topbar,
				.workspace,
				.stage-card,
				.metric-grid {
					grid-template-columns: 1fr;
				}

				.sidebar {
					border-right: 0;
					border-bottom: 1px solid var(--line);
				}

				.status-pill,
				.button {
					width: 100%;
				}

				.visual-token {
					display: none;
				}

				.ops-head {
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>
		<main class="shell">
			<section class="console" aria-label="Telegram bot management console">
				<header class="topbar">
					<div class="brand">
						<div class="brand-mark">SF</div>
						<div>
							<h1>Telegram Bot Management</h1>
							<p>Owner-approved operations for SilentFlare infrastructure bots.</p>
						</div>
					</div>
					<div id="api-health" class="status-pill">Checking API</div>
				</header>

				<div class="workspace">
					<aside class="sidebar">
						<div class="section-head">
							<p class="label">Select bot</p>
							<span class="step">1</span>
						</div>
						<div id="bot-list" class="bot-list">
							<button type="button" class="bot-card" disabled>Loading bots</button>
						</div>
					</aside>

					<section class="main stage">
						<div id="select-stage" class="stage-card">
							<div>
								<p class="label">Verification</p>
								<h2>Select a bot</h2>
								<p>Choose the infrastructure bot you want to unlock. Each bot keeps its own authorization method and session boundary.</p>
							</div>
							<div class="visual-token">01</div>
						</div>

						<div id="auth-stage" class="stage-card hidden">
							<div>
								<p id="auth-method-label" class="label">Telegram authorization</p>
								<h2 id="auth-title">Unlock bot</h2>
								<p id="auth-copy">Approve the request from the fixed Owner account in Telegram.</p>
								<div id="telegram-auth" class="telegram-auth hidden">
									<button id="telegram-start" type="button" class="button">
										Send approval request
									</button>
								</div>
								<form id="auth-form" class="auth-form" autocomplete="off">
									<input
										id="auth-code"
										class="code-input"
										name="code"
										inputmode="numeric"
										pattern="[0-9]{6}"
										minlength="6"
										maxlength="6"
										autocomplete="one-time-code"
										placeholder="000000"
										aria-label="Six-digit authentication code"
										required
									/>
									<button id="auth-submit" type="submit" class="button">Verify</button>
								</form>
								<div id="auth-message" class="message">Waiting for verification.</div>
							</div>
							<div class="visual-token">TG</div>
						</div>

						<div id="ops-stage" class="ops-card hidden">
							<div class="ops-head">
								<div>
									<p id="selected-bot-purpose" class="label">Database backup</p>
									<h2 id="selected-bot-name">Ghost database backup bot</h2>
								</div>
								<div class="action-row">
									<button id="run-backup" type="button" class="button">Run backup</button>
									<button id="logout" type="button" class="button secondary">Lock</button>
								</div>
							</div>

							<div class="metric-grid">
								<div class="metric">
									<span>Timer</span>
									<strong id="backup-timer">Unknown</strong>
								</div>
								<div class="metric">
									<span>Latest backup</span>
									<strong id="backup-latest">Unknown</strong>
								</div>
								<div class="metric">
									<span>Local files</span>
									<strong id="backup-count">0</strong>
								</div>
							</div>

							<div id="backup-message" class="message">Waiting for API status.</div>
							<div id="backup-history" class="history">
								<div class="history-row">
									<strong>No backup history loaded.</strong>
									<span></span>
								</div>
							</div>
						</div>
					</section>
				</div>
			</section>
		</main>

		<script is:inline define:vars={{ apiBase }}>
			const apiHealth = document.getElementById("api-health");
			const botList = document.getElementById("bot-list");
			const selectStage = document.getElementById("select-stage");
			const authStage = document.getElementById("auth-stage");
			const opsStage = document.getElementById("ops-stage");
			const authForm = document.getElementById("auth-form");
			const authCode = document.getElementById("auth-code");
			const authSubmit = document.getElementById("auth-submit");
			const authTitle = document.getElementById("auth-title");
			const authCopy = document.getElementById("auth-copy");
			const authMethodLabel = document.getElementById("auth-method-label");
			const authMessage = document.getElementById("auth-message");
			const telegramAuth = document.getElementById("telegram-auth");
			const telegramStart = document.getElementById("telegram-start");
			const logout = document.getElementById("logout");
			const runBackup = document.getElementById("run-backup");
			const selectedBotName = document.getElementById("selected-bot-name");
			const selectedBotPurpose = document.getElementById("selected-bot-purpose");
			const backupTimer = document.getElementById("backup-timer");
			const backupLatest = document.getElementById("backup-latest");
			const backupCount = document.getElementById("backup-count");
			const backupMessage = document.getElementById("backup-message");
			const backupHistory = document.getElementById("backup-history");

			let csrfToken = sessionStorage.getItem("silentflare_bot_csrf") ?? "";
			let bots = [];
			let selectedBot = null;
			let telegramPoll = null;
			let activeChallenge = null;

			function setHealth(message, tone = "neutral") {
				apiHealth.textContent = message;
				apiHealth.dataset.tone = tone;
			}

			function setAuthMessage(message, tone = "neutral") {
				authMessage.textContent = message;
				authMessage.dataset.tone = tone;
			}

			function setBackupMessage(message, tone = "neutral") {
				backupMessage.textContent = message;
				backupMessage.dataset.tone = tone;
			}

			function showStage(stage) {
				selectStage.classList.toggle("hidden", stage !== "select");
				authStage.classList.toggle("hidden", stage !== "auth");
				opsStage.classList.toggle("hidden", stage !== "ops");
			}

			function stopTelegramPolling() {
				if (telegramPoll) window.clearInterval(telegramPoll);
				telegramPoll = null;
				activeChallenge = null;
			}

			function formatAuthMethod(method) {
				if (method === "totp") return "2FA";
				if (method === "telegram") return "Bot authorization";
				return method;
			}

			function formatSize(value) {
				if (!Number.isFinite(value)) return "0 B";
				if (value < 1024) return `${value} B`;
				if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
				return `${(value / 1024 / 1024).toFixed(1)} MB`;
			}

			async function api(path, options = {}) {
				const headers = {
					Accept: "application/json",
					...(options.body ? { "Content-Type": "application/json" } : {}),
					...(options.csrf ? { "X-CSRF-Token": csrfToken } : {}),
					...(options.headers ?? {}),
				};
				const response = await fetch(`${apiBase}${path}`, {
					...options,
					credentials: "include",
					headers,
				});
				if (response.status === 401 || response.status === 403) {
					if (options.lockOnAuthFailure !== false) showStage(selectedBot ? "auth" : "select");
				}
				if (!response.ok) {
					let detail = `API ${response.status}`;
					try {
						const errorBody = await response.json();
						detail = errorBody.detail ?? detail;
					} catch {
						// Keep the status-based message.
					}
					throw new Error(detail);
				}
				return response.json();
			}

			function selectBot(bot) {
				selectedBot = bot;
				sessionStorage.setItem("silentflare_selected_bot", bot.id);
				for (const item of botList.querySelectorAll(".bot-card")) {
					item.setAttribute("aria-pressed", String(item.dataset.botId === bot.id));
				}
				selectedBotName.textContent = bot.name;
				selectedBotPurpose.textContent = bot.purpose;
				authTitle.textContent = `Unlock ${bot.name}`;
				authMethodLabel.textContent = `${formatAuthMethod(bot.auth_method)} verification`;
				authCopy.textContent =
					bot.auth_method === "totp"
						? "Enter the 6-digit authenticator code assigned to this bot."
						: "Approve the login request from the fixed Owner account in Telegram.";
				authCode.value = "";
				stopTelegramPolling();
				authForm.classList.toggle("hidden", bot.auth_method !== "totp");
				telegramAuth.classList.toggle("hidden", bot.auth_method !== "telegram");
				telegramStart.disabled = false;
				telegramStart.textContent = "Send approval request";
				setAuthMessage("Waiting for verification.");
				showStage("auth");
				if (bot.auth_method === "totp") window.setTimeout(() => authCode?.focus(), 0);
			}

			function renderBots() {
				botList.textContent = "";
				for (const bot of bots) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = "bot-card";
					button.dataset.botId = bot.id;
					button.setAttribute("aria-pressed", String(selectedBot?.id === bot.id));
					button.innerHTML = `
						<strong></strong>
						<small></small>
						<div class="bot-meta">
							<span class="chip" data-tone="ready"></span>
							<span class="chip"></span>
						</div>
					`;
					button.querySelector("strong").textContent = bot.name;
					button.querySelector("small").textContent = bot.purpose;
					const chips = button.querySelectorAll(".chip");
					chips[0].textContent = bot.status;
					chips[1].textContent = formatAuthMethod(bot.auth_method);
					button.addEventListener("click", () => selectBot(bot));
					botList.append(button);
				}
			}

			function renderStatus(status) {
				backupTimer.textContent = status.timer_active ? "Active" : "Inactive";
				backupLatest.textContent = status.latest?.created_at ?? "None";
				backupCount.textContent = String(status.backups.length);
				backupHistory.textContent = "";

				if (status.backups.length === 0) {
					const empty = document.createElement("div");
					empty.className = "history-row";
					const name = document.createElement("strong");
					name.textContent = "No local backups found.";
					empty.append(name, document.createElement("span"));
					backupHistory.append(empty);
					return;
				}

				for (const item of status.backups) {
					const row = document.createElement("div");
					row.className = "history-row";
					const name = document.createElement("strong");
					name.textContent = item.filename;
					const size = document.createElement("span");
					size.textContent = formatSize(item.size);
					row.append(name, size);
					backupHistory.append(row);
				}
			}

			async function loadStatus() {
				if (!selectedBot) return;
				try {
					const status = await api(`/bots/${selectedBot.id}/backup/status`);
					renderStatus(status);
					setBackupMessage(status.message ?? "Backup status loaded.", "success");
				} catch (error) {
					setBackupMessage(`Unable to load backup status: ${error.message}`, "error");
				}
			}

			async function enterOps(bot) {
				stopTelegramPolling();
				selectedBot = bot;
				selectedBotName.textContent = bot.name;
				selectedBotPurpose.textContent = bot.purpose;
				showStage("ops");
				await loadStatus();
			}

			async function checkTelegramChallenge() {
				if (!selectedBot || !activeChallenge) return;
				try {
					const result = await api(
						`/auth/telegram/status/${activeChallenge}?bot_id=${encodeURIComponent(selectedBot.id)}`,
						{ lockOnAuthFailure: false },
					);
					if (result.status !== "approved") return;
					csrfToken = result.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					setAuthMessage("Telegram authorization approved.", "success");
					await enterOps(result.bot);
				} catch (error) {
					stopTelegramPolling();
					telegramStart.disabled = false;
					telegramStart.textContent = "Send approval request";
					setAuthMessage(`Authorization failed: ${error.message}`, "error");
				}
			}

			async function startTelegramAuthorization() {
				if (!selectedBot) return;
				telegramStart.disabled = true;
				telegramStart.textContent = "Waiting for Owner approval";
				stopTelegramPolling();
				try {
					const result = await api("/auth/telegram/start", {
						method: "POST",
						body: JSON.stringify({ bot_id: selectedBot.id }),
						lockOnAuthFailure: false,
					});
					activeChallenge = result.challenge_id;
					setAuthMessage("Approval request sent to Telegram. Confirm from the Owner account.");
					telegramPoll = window.setInterval(checkTelegramChallenge, 1800);
					await checkTelegramChallenge();
				} catch (error) {
					telegramStart.disabled = false;
					telegramStart.textContent = "Send approval request";
					setAuthMessage(`Unable to send approval request: ${error.message}`, "error");
				}
			}

			async function boot() {
				try {
					const health = await api("/health", { lockOnAuthFailure: false });
					setHealth(health.ok ? "API online" : "API degraded");
				} catch {
					setHealth("API offline", "error");
				}

				try {
					const list = await api("/bots", { lockOnAuthFailure: false });
					bots = list.bots;
					const remembered = sessionStorage.getItem("silentflare_selected_bot");
					selectedBot = bots.find((bot) => bot.id === remembered) ?? null;
					renderBots();
				} catch (error) {
					botList.textContent = "";
					const item = document.createElement("div");
					item.className = "message";
					item.dataset.tone = "error";
					item.textContent = `Unable to load bots: ${error.message}`;
					botList.append(item);
				}

				try {
					const session = await api("/auth/me", { lockOnAuthFailure: false });
					csrfToken = session.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					await enterOps(session.bot);
				} catch {
					showStage(selectedBot ? "auth" : "select");
				}
			}

			authForm?.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (!selectedBot) return;
				if (selectedBot.auth_method !== "totp") return;
				authSubmit.disabled = true;
				authSubmit.textContent = "Verifying";
				try {
					const result = await api("/auth/login", {
						method: "POST",
						body: JSON.stringify({
							bot_id: selectedBot.id,
							method: selectedBot.auth_method,
							code: authCode.value,
						}),
						lockOnAuthFailure: false,
					});
					csrfToken = result.csrf;
					sessionStorage.setItem("silentflare_bot_csrf", csrfToken);
					setAuthMessage("Verification accepted.", "success");
					await enterOps(result.bot);
				} catch (error) {
					setAuthMessage(`Verification failed: ${error.message}`, "error");
				} finally {
					authSubmit.disabled = false;
					authSubmit.textContent = "Verify";
				}
			});

			telegramStart?.addEventListener("click", () => {
				startTelegramAuthorization();
			});

			logout?.addEventListener("click", async () => {
				try {
					await api("/auth/logout", { method: "POST", csrf: true });
				} catch {
					// Local state still clears if the remote session already expired.
				}
				csrfToken = "";
				sessionStorage.removeItem("silentflare_bot_csrf");
				stopTelegramPolling();
				showStage(selectedBot ? "auth" : "select");
			});

			runBackup?.addEventListener("click", async () => {
				if (!selectedBot) return;
				runBackup.disabled = true;
				runBackup.textContent = "Running";
				setBackupMessage("Backup job started.");
				try {
					const result = await api(`/bots/${selectedBot.id}/backup/run`, {
						method: "POST",
						csrf: true,
					});
					setBackupMessage(result.message ?? "Backup completed.", "success");
					await loadStatus();
				} catch (error) {
					setBackupMessage(`Backup failed: ${error.message}`, "error");
				} finally {
					runBackup.disabled = false;
					runBackup.textContent = "Run backup";
				}
			});

			boot();
		</script>
	</body>
</html>
