---
const apiBase =
	import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.silentflare.com";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Telegram Bot Management</title>
		<meta name="description" content="SilentFlare bot operations dashboard" />
		<style is:global>
			:root {
				color-scheme: light;
				--bg: #eef3f7;
				--rail: #111827;
				--surface: #ffffff;
				--surface-soft: #f7f9fc;
				--line: #d7e0ea;
				--line-soft: #e7edf4;
				--text: #121a27;
				--muted: #667386;
				--blue: #2563eb;
				--blue-dark: #1d4ed8;
				--blue-soft: #e8f1ff;
				--green: #12834c;
				--green-soft: #e9f8f0;
				--amber: #9a6500;
				--amber-soft: #fff7df;
				--red: #b42318;
				--red-soft: #fff1f0;
				--radius: 8px;
				--shadow: 0 18px 46px rgba(29, 45, 65, 0.1);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: var(--bg);
				color: var(--text);
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
					sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			button,
			input {
				font: inherit;
				letter-spacing: 0;
			}

			button {
				cursor: pointer;
			}

			button:disabled {
				cursor: not-allowed;
				opacity: 0.55;
			}

			h1,
			h2,
			h3,
			p {
				margin: 0;
			}

			.icon {
				width: 1rem;
				height: 1rem;
				flex: none;
				stroke: currentColor;
				stroke-width: 2;
				stroke-linecap: round;
				stroke-linejoin: round;
				fill: none;
			}

			.icon * {
				fill: none;
			}

			.hidden {
				display: none !important;
			}

			.login-page {
				display: grid;
				min-height: 100vh;
				place-items: center;
				padding: 1.2rem;
			}

			.login-card {
				display: grid;
				gap: 1.2rem;
				width: min(31rem, 100%);
				border: 1px solid var(--line);
				border-radius: 16px;
				background: var(--surface);
				padding: clamp(1.2rem, 4vw, 2rem);
				box-shadow: var(--shadow);
			}

			.brand {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				min-width: 0;
			}

			.brand-mark {
				display: grid;
				width: 2.5rem;
				height: 2.5rem;
				place-items: center;
				border-radius: 10px;
				background: var(--blue);
				color: #ffffff;
				font-weight: 850;
			}

			.brand strong,
			.brand span {
				display: block;
			}

			.brand span {
				margin-top: 0.14rem;
				color: var(--muted);
				font-size: 0.82rem;
			}

			.login-card h1 {
				font-size: clamp(1.7rem, 5vw, 2.35rem);
				line-height: 1.08;
			}

			.login-card > p {
				color: var(--muted);
				font-size: 0.95rem;
				line-height: 1.55;
			}

			.method-grid {
				display: grid;
				gap: 0.8rem;
			}

			.method-card {
				display: grid;
				gap: 0.75rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #fbfdff;
				padding: 1rem;
			}

			.method-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
			}

			.method-head h2 {
				font-size: 1rem;
			}

			.method-card p {
				color: var(--muted);
				font-size: 0.84rem;
				line-height: 1.5;
			}

			.code-row {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 0.6rem;
			}

			input {
				width: 100%;
				min-height: 2.75rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				color: var(--text);
				padding: 0 0.85rem;
				outline: none;
			}

			input:focus {
				border-color: #9fc2ff;
				box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
			}

			.button {
				display: inline-flex;
				min-height: 2.65rem;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				color: var(--text);
				padding: 0.65rem 0.9rem;
				font-weight: 760;
				white-space: nowrap;
			}

			.button.primary {
				border-color: var(--blue);
				background: var(--blue);
				color: #ffffff;
			}

			.button.primary:hover {
				background: var(--blue-dark);
			}

			.button.danger {
				border-color: #efb5ae;
				color: var(--red);
			}

			.button.ghost {
				background: transparent;
				color: var(--muted);
			}

			.message {
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: var(--surface-soft);
				color: var(--muted);
				padding: 0.75rem 0.85rem;
				font-size: 0.84rem;
				line-height: 1.45;
			}

			.message[data-tone="success"] {
				border-color: #bbe4ca;
				background: var(--green-soft);
				color: var(--green);
			}

			.message[data-tone="warning"] {
				border-color: #f0d593;
				background: var(--amber-soft);
				color: var(--amber);
			}

			.message[data-tone="error"] {
				border-color: #efb5ae;
				background: var(--red-soft);
				color: var(--red);
			}

			.app {
				display: grid;
				grid-template-columns: 15rem minmax(0, 1fr);
				gap: 0.75rem;
				height: 100vh;
				padding: 0.75rem;
			}

			.rail {
				display: grid;
				grid-template-rows: auto auto 1fr auto;
				min-width: 0;
				overflow: hidden;
				border-radius: 14px;
				background: var(--rail);
				color: #f8fafc;
				padding: 0.85rem;
			}

			.rail .brand {
				padding-bottom: 1rem;
			}

			.rail .brand span {
				color: #a7b2c3;
			}

			.nav {
				display: grid;
				gap: 0.35rem;
				margin-bottom: 1rem;
			}

			.nav-label {
				margin: 0.4rem 0.45rem;
				color: #8f9bad;
				font-size: 0.68rem;
				font-weight: 800;
				text-transform: uppercase;
			}

			.nav button,
			.logout {
				display: grid;
				grid-template-columns: 1.1rem minmax(0, 1fr);
				align-items: center;
				gap: 0.65rem;
				width: 100%;
				min-height: 2.55rem;
				border: 0;
				border-radius: var(--radius);
				background: transparent;
				color: #cbd5e1;
				padding: 0 0.65rem;
				font-size: 0.86rem;
				text-align: left;
			}

			.nav button.active,
			.nav button:hover,
			.logout:hover {
				background: #243244;
				color: #ffffff;
			}

			.bot-list {
				display: grid;
				gap: 0.55rem;
				align-content: start;
				overflow: auto;
			}

			.login-bot-list {
				max-height: 15rem;
			}

			.login-bot-list .bot-card {
				border-color: var(--line);
				background: #ffffff;
				color: var(--text);
			}

			.login-bot-list .bot-card[aria-pressed="true"],
			.login-bot-list .bot-card:hover {
				border-color: #9fc2ff;
				background: var(--blue-soft);
			}

			.login-bot-list .bot-card small {
				color: var(--muted);
			}

			.bot-card {
				display: grid;
				grid-template-columns: 2rem minmax(0, 1fr);
				gap: 0.65rem;
				align-items: center;
				width: 100%;
				min-height: 3.6rem;
				border: 1px solid rgba(203, 213, 225, 0.2);
				border-radius: var(--radius);
				background: rgba(255, 255, 255, 0.04);
				color: #f8fafc;
				padding: 0.65rem;
				text-align: left;
			}

			.bot-card > span:last-child {
				display: grid;
				gap: 0.12rem;
				min-width: 0;
			}

			.bot-card[aria-pressed="true"],
			.bot-card:hover {
				border-color: rgba(147, 197, 253, 0.55);
				background: #243244;
			}

			.bot-icon {
				display: grid;
				width: 2rem;
				height: 2rem;
				place-items: center;
				border-radius: var(--radius);
				background: var(--blue);
				color: #ffffff;
			}

			.bot-icon .icon {
				width: 1rem;
				height: 1rem;
			}

			.bot-card strong,
			.bot-card small {
				display: block;
				min-width: 0;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.bot-card small {
				color: #a7b2c3;
				font-size: 0.75rem;
				line-height: 1.28;
			}

			.rail-status {
				display: grid;
				gap: 0.55rem;
				border: 1px solid rgba(203, 213, 225, 0.18);
				border-radius: 12px;
				padding: 0.85rem;
				color: #dbe6f4;
				font-size: 0.78rem;
			}

			.rail-status strong {
				color: #86efac;
			}

			.shell {
				display: grid;
				grid-template-rows: auto minmax(0, 1fr);
				min-width: 0;
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: 14px;
				background: var(--surface);
				box-shadow: var(--shadow);
			}

			.topbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				min-height: 4.5rem;
				border-bottom: 1px solid var(--line);
				padding: 0.9rem 1.5rem;
			}

			.topbar h1 {
				font-size: clamp(1.25rem, 2vw, 1.72rem);
				line-height: 1.15;
			}

			.topbar p {
				margin-top: 0.22rem;
				color: var(--muted);
				font-size: 0.86rem;
			}

			.status-pill,
			.chip {
				display: inline-flex;
				min-height: 2rem;
				align-items: center;
				justify-content: center;
				border: 1px solid #b9e4c8;
				border-radius: 999px;
				background: var(--green-soft);
				color: var(--green);
				padding: 0.35rem 0.72rem;
				font-size: 0.76rem;
				font-weight: 760;
				white-space: nowrap;
			}

			.chip.neutral {
				border-color: var(--line);
				background: #f8fafc;
				color: var(--muted);
			}

			.content {
				min-height: 0;
				overflow: auto;
				padding: 1rem 1.5rem;
			}

			.grid {
				display: grid;
				grid-template-columns: minmax(20rem, 0.9fr) minmax(22rem, 1.1fr);
				gap: 1rem;
			}

			.panel {
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				overflow: hidden;
			}

			.panel-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				min-height: 3.2rem;
				border-bottom: 1px solid var(--line-soft);
				padding: 0.72rem 0.9rem;
			}

			.panel-head h2 {
				font-size: 1rem;
			}

			.panel-body {
				display: grid;
				gap: 0.85rem;
				padding: 0.9rem;
			}

			.action-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem;
			}

			.metric-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				border: 1px solid var(--line);
				border-radius: var(--radius);
				overflow: hidden;
			}

			.metric {
				min-height: 4.8rem;
				border-left: 1px solid var(--line-soft);
				padding: 0.75rem;
			}

			.metric:first-child {
				border-left: 0;
			}

			.metric span {
				display: block;
				color: var(--muted);
				font-size: 0.73rem;
				font-weight: 760;
			}

			.metric strong {
				display: block;
				margin-top: 0.45rem;
				overflow-wrap: anywhere;
				font-size: 0.92rem;
			}

			table {
				width: 100%;
				min-width: 48rem;
				border-collapse: collapse;
				font-size: 0.82rem;
			}

			th,
			td {
				border-bottom: 1px solid var(--line-soft);
				padding: 0.72rem 0.85rem;
				text-align: left;
				vertical-align: middle;
			}

			th {
				color: var(--muted);
				font-size: 0.72rem;
				font-weight: 800;
			}

			.table-wrap {
				overflow: auto;
			}

			.mono {
				font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
			}

			.empty-state {
				color: var(--muted);
				padding: 1.2rem;
				text-align: center;
			}

			.activity {
				display: grid;
				max-height: 14rem;
				overflow: auto;
			}

			.activity-row {
				display: grid;
				grid-template-columns: 5.5rem minmax(0, 1fr) 5.5rem;
				gap: 0.75rem;
				align-items: center;
				border-top: 1px solid var(--line-soft);
				padding: 0.7rem 0.9rem;
				color: var(--muted);
				font-size: 0.8rem;
			}

			.activity-row:first-child {
				border-top: 0;
			}

			.activity-row strong {
				min-width: 0;
				overflow: hidden;
				color: var(--text);
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.settings-grid {
				display: grid;
				grid-template-columns: minmax(18rem, 0.8fr) minmax(24rem, 1.2fr);
				gap: 1rem;
			}

			.secret-box {
				display: grid;
				gap: 0.4rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: var(--surface-soft);
				padding: 0.75rem;
				overflow-wrap: anywhere;
			}

			.totp-qr {
				width: 11rem;
				height: 11rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: #ffffff;
				padding: 0.5rem;
			}

			.notice {
				position: fixed;
				left: 50%;
				bottom: 1rem;
				z-index: 40;
				transform: translateX(-50%) translateY(0.5rem);
				border-radius: var(--radius);
				background: #111827;
				color: #ffffff;
				padding: 0.7rem 0.9rem;
				font-size: 0.84rem;
				opacity: 0;
				pointer-events: none;
				transition:
					opacity 160ms ease,
					transform 160ms ease;
			}

			.notice.show {
				transform: translateX(-50%);
				opacity: 1;
			}

			@media (max-width: 1080px) {
				.app {
					grid-template-columns: 1fr;
					height: auto;
					min-height: 100vh;
					padding: 0;
				}

				.rail,
				.shell {
					border-radius: 0;
				}

				.rail {
					grid-template-rows: auto auto auto auto;
				}

				.bot-list {
					grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
					max-height: none;
				}

				.grid,
				.settings-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				.topbar,
				.method-head {
					align-items: stretch;
					flex-direction: column;
				}

				.content {
					padding: 0.85rem;
				}

				.code-row,
				.metric-grid,
				.activity-row {
					grid-template-columns: 1fr;
				}

				.metric {
					border-left: 0;
					border-top: 1px solid var(--line-soft);
				}

				.metric:first-child {
					border-top: 0;
				}

				.button {
					width: 100%;
				}
			}
		</style>
	</head>
	<body data-api-base={apiBase}>
		<svg aria-hidden="true" width="0" height="0" class="hidden">
			<symbol id="icon-bot" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="5" y="8" width="14" height="10" rx="3" /><path d="M12 8V4" /><path d="M9 4h6" /><path d="M9 13h.01" /><path d="M15 13h.01" /></symbol>
			<symbol id="icon-send" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m22 2-7 20-4-9-9-4 20-7Z" /><path d="M22 2 11 13" /></symbol>
			<symbol id="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="5" y="11" width="14" height="10" rx="2" /><path d="M8 11V7a4 4 0 0 1 8 0v4" /></symbol>
			<symbol id="icon-db" viewBox="0 0 24 24" fill="none" stroke="currentColor"><ellipse cx="12" cy="5" rx="8" ry="3" /><path d="M4 5v14c0 1.7 3.6 3 8 3s8-1.3 8-3V5" /><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3" /></symbol>
			<symbol id="icon-refresh" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 12a9 9 0 0 1-15.5 6.2" /><path d="M3 12A9 9 0 0 1 18.5 5.8" /><path d="M18 2v4h4" /><path d="M6 22v-4H2" /></symbol>
			<symbol id="icon-settings" viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.4 1.1V21a2 2 0 1 1-4 0v-.09A1.7 1.7 0 0 0 8.6 19.4a1.7 1.7 0 0 0-1.88.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 0-1.1-.4H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.6 8.6a1.7 1.7 0 0 0-.34-1.88l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 0 .4-1.1V3a2 2 0 1 1 4 0v.09A1.7 1.7 0 0 0 15.4 4.6a1.7 1.7 0 0 0 1.88-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9c.4.2.73.5 1 .9.27.4.4.8.4 1.1V11a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-1.31 1Z" /></symbol>
		</svg>

		<section id="login-page" class="login-page">
			<div class="login-card">
				<div class="brand">
					<div class="brand-mark">SF</div>
					<div>
						<strong>SilentFlare</strong>
						<span>Bot operations</span>
					</div>
				</div>
				<div>
					<h1>Telegram Bot Management</h1>
					<p>Choose a bot first, then verify access for that bot.</p>
				</div>
				<div id="bot-step" class="method-grid">
					<section class="method-card">
						<div>
							<h2>Select bot</h2>
							<p>Pick the bot backend you want to operate.</p>
						</div>
						<div id="login-bot-list" class="bot-list login-bot-list"></div>
					</section>
					<div id="login-message" class="message">Loading bot list.</div>
				</div>
				<div id="auth-step" class="method-grid hidden">
					<section class="method-card">
						<div class="method-head">
							<div>
								<h2 id="auth-title">Verify bot access</h2>
								<p id="auth-subtitle">Confirm access before opening this bot backend.</p>
							</div>
							<button id="change-bot" type="button" class="button ghost">
								<span>Change bot</span>
							</button>
						</div>
					</section>
					<section class="method-card">
						<div class="method-head">
							<div>
								<h2>Telegram Bot authorization</h2>
								<p>Send a one-time approval request for the selected bot.</p>
							</div>
							<button id="login-telegram" type="button" class="button primary" disabled>
								<svg class="icon"><use href="#icon-send"></use></svg>
								<span>Send approval request</span>
							</button>
						</div>
						<div id="login-telegram-message" class="message">Waiting to send an approval request.</div>
					</section>
					<section class="method-card">
						<div>
							<h2>Authenticator 2FA</h2>
							<p>Use the six-digit Owner code for the selected bot.</p>
						</div>
						<form id="login-totp-form" class="code-row" autocomplete="off">
							<input id="login-totp-code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" aria-label="Six-digit authentication code" disabled />
							<button id="login-totp-submit" type="submit" class="button" disabled>
								<svg class="icon"><use href="#icon-lock"></use></svg>
								<span>Verify 2FA</span>
							</button>
						</form>
					</section>
					<div id="login-message-auth" class="message">Choose a verification method.</div>
				</div>
			</div>
		</section>

		<section id="app-page" class="app hidden">
			<aside class="rail">
				<div class="brand">
					<div class="brand-mark">SF</div>
					<div>
						<strong>SilentFlare</strong>
						<span>Owner console</span>
					</div>
				</div>
				<nav class="nav" aria-label="Console navigation">
					<p class="nav-label">Console</p>
					<button id="nav-dashboard" type="button" class="active" data-view="dashboard">
						<svg class="icon"><use href="#icon-db"></use></svg>
						<span>Dashboard</span>
					</button>
					<button id="nav-settings" type="button" data-view="settings">
						<svg class="icon"><use href="#icon-settings"></use></svg>
						<span>Settings</span>
					</button>
				</nav>
				<div>
					<p class="nav-label">Bots</p>
					<div id="bot-list" class="bot-list"></div>
				</div>
				<div class="rail-status">
					<div><strong id="rail-api">API online</strong></div>
					<div>Session: <strong id="rail-session">Owner verified</strong></div>
					<button id="logout" type="button" class="logout">
						<svg class="icon"><use href="#icon-lock"></use></svg>
						<span>Lock session</span>
					</button>
				</div>
			</aside>

			<main class="shell">
				<header class="topbar">
					<div>
						<h1 id="page-title">Select a bot</h1>
						<p id="page-subtitle">Choose one bot from the left rail to open its management backend.</p>
					</div>
					<div class="status-pill">Owner verified</div>
				</header>

				<section id="dashboard-view" class="content">
					<div class="grid">
						<section class="panel">
							<div class="panel-head">
								<h2>Selected bot</h2>
								<span id="selected-status" class="chip neutral">None selected</span>
							</div>
							<div class="panel-body">
								<div class="message" id="selected-message">Select a bot to load operations.</div>
								<div class="action-row">
									<button id="refresh-status" type="button" class="button" disabled>
										<svg class="icon"><use href="#icon-refresh"></use></svg>
										<span>Refresh</span>
									</button>
									<button id="telegram-test" type="button" class="button" disabled>
										<svg class="icon"><use href="#icon-send"></use></svg>
										<span>Test Telegram</span>
									</button>
									<button id="run-backup" type="button" class="button primary" disabled>
										<svg class="icon"><use href="#icon-db"></use></svg>
										<span>Run backup</span>
									</button>
								</div>
								<div class="metric-grid">
									<div class="metric"><span>Timer active</span><strong id="backup-timer">Unknown</strong></div>
									<div class="metric"><span>Latest backup</span><strong id="backup-latest">Unknown</strong></div>
									<div class="metric"><span>Local backups</span><strong id="backup-count">0 files</strong></div>
								</div>
							</div>
						</section>

						<section class="panel">
							<div class="panel-head">
								<h2>Activity</h2>
								<button id="clear-activity" type="button" class="button ghost">Clear</button>
							</div>
							<div id="activity" class="activity"></div>
						</section>
					</div>

					<section class="panel" style="margin-top: 1rem">
						<div class="panel-head">
							<h2>Recent backups</h2>
							<span id="backup-auto" class="chip neutral">Auto refresh paused</span>
						</div>
						<div class="table-wrap">
							<table>
								<thead>
									<tr>
										<th>Filename</th>
										<th>Created at</th>
										<th>Size</th>
										<th>SHA256 short</th>
										<th>Result</th>
									</tr>
								</thead>
								<tbody id="backup-history">
									<tr><td colspan="5"><div class="empty-state">No bot selected.</div></td></tr>
								</tbody>
							</table>
						</div>
					</section>
				</section>

				<section id="settings-view" class="content hidden">
					<div class="settings-grid">
						<section class="panel">
							<div class="panel-head">
								<h2>Account security</h2>
								<span id="totp-state" class="chip neutral">2FA unknown</span>
							</div>
							<div class="panel-body">
								<p class="message">Telegram approval remains available. Use this panel to reset the Owner authenticator for future 2FA logins.</p>
								<button id="generate-totp" type="button" class="button primary">Generate new 2FA setup</button>
							</div>
						</section>

						<section class="panel">
							<div class="panel-head">
								<h2>Authenticator setup</h2>
								<span class="chip neutral">Owner only</span>
							</div>
							<div class="panel-body">
								<div id="totp-secret-box" class="secret-box hidden">
									<strong>Scan QR code</strong>
									<canvas id="totp-qr" class="totp-qr" aria-label="Authenticator QR code"></canvas>
									<strong>Manual secret</strong>
									<span id="totp-secret" class="mono"></span>
									<strong>otpauth URI</strong>
									<span id="totp-uri" class="mono"></span>
								</div>
								<form id="enable-totp-form" class="code-row hidden" autocomplete="off">
									<input id="enable-totp-code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" aria-label="Six-digit setup confirmation code" />
									<button id="enable-totp" type="submit" class="button primary">Enable 2FA</button>
								</form>
								<div id="settings-message" class="message">Generate a setup code first.</div>
							</div>
						</section>
					</div>
				</section>
			</main>
		</section>

		<div id="notice" class="notice" role="status" aria-live="polite"></div>

		<script>
			// @ts-nocheck
			import QRCode from "qrcode";

			const apiBase = document.body.dataset.apiBase ?? "https://api.silentflare.com";
			const state = {
				activeChallenge: "",
				activity: [],
				bots: [],
				challengeExpiresAt: null,
				countdownTimer: null,
				csrf: sessionStorage.getItem("silentflare_bot_csrf") ?? "",
				loginMethods: { telegram: false, totp: false },
				pollTimer: null,
				selectedBot: null,
				statusTimer: null,
				totpSecret: "",
			};

			const $ = (id) => document.getElementById(id);
			const nodes = {
				activity: $("activity"),
				appPage: $("app-page"),
				backupAuto: $("backup-auto"),
				backupCount: $("backup-count"),
				backupHistory: $("backup-history"),
				backupLatest: $("backup-latest"),
				backupTimer: $("backup-timer"),
				authStep: $("auth-step"),
				authSubtitle: $("auth-subtitle"),
				authTitle: $("auth-title"),
				botStep: $("bot-step"),
				botList: $("bot-list"),
				changeBot: $("change-bot"),
				dashboardView: $("dashboard-view"),
				enableTotpCode: $("enable-totp-code"),
				enableTotpForm: $("enable-totp-form"),
				generateTotp: $("generate-totp"),
				loginBotList: $("login-bot-list"),
				loginMessage: $("login-message"),
				loginMessageAuth: $("login-message-auth"),
				loginPage: $("login-page"),
				loginTelegram: $("login-telegram"),
				loginTelegramMessage: $("login-telegram-message"),
				loginTotpCode: $("login-totp-code"),
				loginTotpForm: $("login-totp-form"),
				logout: $("logout"),
				navDashboard: $("nav-dashboard"),
				navSettings: $("nav-settings"),
				notice: $("notice"),
				pageSubtitle: $("page-subtitle"),
				pageTitle: $("page-title"),
				refreshStatus: $("refresh-status"),
				runBackup: $("run-backup"),
				selectedMessage: $("selected-message"),
				selectedStatus: $("selected-status"),
				settingsMessage: $("settings-message"),
				settingsView: $("settings-view"),
				telegramTest: $("telegram-test"),
				totpSecret: $("totp-secret"),
				totpSecretBox: $("totp-secret-box"),
				totpQr: $("totp-qr"),
				totpState: $("totp-state"),
				totpUri: $("totp-uri"),
			};

			function icon(name) {
				return `<svg class="icon"><use href="#icon-${name}"></use></svg>`;
			}

			function setMessage(node, message, tone = "neutral") {
				node.textContent = message;
				node.dataset.tone = tone;
			}

			function toast(message) {
				nodes.notice.textContent = message;
				nodes.notice.classList.add("show");
				window.setTimeout(() => nodes.notice.classList.remove("show"), 2400);
			}

			function addActivity(label, detail = "", tone = "neutral") {
				state.activity.unshift({ label, detail, tone, time: new Date().toLocaleTimeString() });
				state.activity = state.activity.slice(0, 30);
				renderActivity();
				if (tone !== "neutral") toast(label);
			}

			function renderActivity() {
				nodes.activity.textContent = "";
				if (state.activity.length === 0) {
					const empty = document.createElement("div");
					empty.className = "empty-state";
					empty.textContent = "No activity yet.";
					nodes.activity.append(empty);
					return;
				}
				for (const item of state.activity) {
					const row = document.createElement("div");
					row.className = "activity-row";
					const time = document.createElement("span");
					time.textContent = item.time;
					const label = document.createElement("strong");
					label.textContent = item.label;
					if (item.detail) label.title = item.detail;
					const tone = document.createElement("span");
					tone.className = "chip neutral";
					tone.textContent = item.tone;
					row.append(time, label, tone);
					nodes.activity.append(row);
				}
			}

			function renderLoginBots() {
				nodes.loginBotList.textContent = "";
				if (state.bots.length === 0) {
					const empty = document.createElement("div");
					empty.className = "message";
					empty.textContent = "No bots available.";
					nodes.loginBotList.append(empty);
					return;
				}
				for (const bot of state.bots) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = "bot-card";
					button.setAttribute("aria-pressed", String(state.selectedBot?.id === bot.id));
					button.innerHTML = `<span class="bot-icon">${icon("bot")}</span><span><strong></strong><small></small></span>`;
					button.querySelector("strong").textContent = bot.id;
					button.querySelector("small").textContent = `${bot.purpose} / ${bot.status}`;
					button.addEventListener("click", () => selectLoginBot(bot));
					nodes.loginBotList.append(button);
				}
			}

			function setAuthControlsEnabled(enabled) {
				nodes.loginTelegram.disabled = !enabled || !state.loginMethods.telegram;
				nodes.loginTotpCode.disabled = !enabled || !state.loginMethods.totp;
				$("login-totp-submit").disabled = !enabled || !state.loginMethods.totp;
			}

			function showBotStep() {
				stopLoginPolling();
				nodes.authStep.classList.add("hidden");
				nodes.botStep.classList.remove("hidden");
				setAuthControlsEnabled(false);
				nodes.loginTotpCode.value = "";
			}

			function showAuthStep() {
				if (!state.selectedBot) return;
				nodes.botStep.classList.add("hidden");
				nodes.authStep.classList.remove("hidden");
				nodes.authTitle.textContent = `Verify ${state.selectedBot.id}`;
				nodes.authSubtitle.textContent = `${state.selectedBot.purpose} / ${state.selectedBot.status}`;
				setAuthControlsEnabled(true);
				setMessage(nodes.loginMessageAuth, "Choose Telegram approval or 2FA to continue.", "neutral");
				setMessage(nodes.loginTelegramMessage, "Ready to send an approval request for the selected bot.");
			}

			function handleAuthExpired(message = "Session expired. Verify this bot again.") {
				state.csrf = "";
				sessionStorage.removeItem("silentflare_bot_csrf");
				stopStatusAutoRefresh();
				nodes.appPage.classList.add("hidden");
				nodes.loginPage.classList.remove("hidden");
				if (state.selectedBot) {
					showAuthStep();
					setMessage(nodes.loginMessageAuth, message, "warning");
				} else {
					showBotStep();
					setMessage(nodes.loginMessage, message, "warning");
				}
			}

			function selectLoginBot(bot) {
				state.selectedBot = bot;
				sessionStorage.setItem("silentflare_selected_bot", bot.id);
				renderLoginBots();
				showAuthStep();
			}

			async function api(path, options = {}) {
				const headers = {
					Accept: "application/json",
					...(options.body ? { "Content-Type": "application/json" } : {}),
					...(options.csrf ? { "X-CSRF-Token": state.csrf } : {}),
					...(options.headers ?? {}),
				};
				let response;
				try {
					response = await fetch(`${apiBase}${path}`, {
						...options,
						credentials: "include",
						headers,
					});
				} catch (error) {
					if (options.lockOnAuthFailure !== false) {
						handleAuthExpired("The API request failed. Verify this bot again.");
					}
					throw error;
				}
				if (!response.ok) {
					let detail = `API ${response.status}`;
					try {
						const body = await response.json();
						detail = body.detail ?? detail;
					} catch {
						// Keep status-based detail.
					}
					if ((response.status === 401 || response.status === 403) && options.lockOnAuthFailure !== false) {
						handleAuthExpired(detail);
					}
					throw new Error(detail);
				}
				return response.json();
			}

			function stopLoginPolling() {
				if (state.pollTimer) window.clearInterval(state.pollTimer);
				if (state.countdownTimer) window.clearInterval(state.countdownTimer);
				state.pollTimer = null;
				state.countdownTimer = null;
				state.activeChallenge = "";
				state.challengeExpiresAt = null;
				setAuthControlsEnabled(Boolean(state.selectedBot));
			}

			function updateLoginCountdown() {
				if (!state.challengeExpiresAt) return;
				const remaining = Math.max(0, Math.round((state.challengeExpiresAt.getTime() - Date.now()) / 1000));
				const minutes = Math.floor(remaining / 60);
				const seconds = String(remaining % 60).padStart(2, "0");
				setMessage(
					nodes.loginTelegramMessage,
					remaining > 0
						? `Approval request sent. Waiting for Telegram approval (${minutes}:${seconds}).`
						: "Approval request expired. Send a new request.",
					remaining > 0 ? "neutral" : "warning",
				);
				if (remaining <= 0) stopLoginPolling();
			}

			async function startTelegramLogin() {
				if (!state.selectedBot) {
					setMessage(nodes.loginMessage, "Select a bot before verification.", "warning");
					return;
				}
				stopLoginPolling();
				nodes.loginTelegram.disabled = true;
				try {
					const result = await api("/auth/telegram/start", {
						method: "POST",
						body: JSON.stringify({ bot_id: state.selectedBot.id }),
						lockOnAuthFailure: false,
					});
					state.activeChallenge = result.challenge_id;
					state.challengeExpiresAt = new Date(result.expires_at);
					updateLoginCountdown();
					state.countdownTimer = window.setInterval(updateLoginCountdown, 1000);
					state.pollTimer = window.setInterval(checkTelegramLogin, 1600);
					await checkTelegramLogin();
				} catch (error) {
					stopLoginPolling();
					setMessage(nodes.loginTelegramMessage, `Unable to send approval request: ${error.message}`, "error");
				}
			}

			async function checkTelegramLogin() {
				if (!state.activeChallenge || !state.selectedBot) return;
				try {
					const result = await api(
						`/auth/telegram/status/${state.activeChallenge}?bot_id=${encodeURIComponent(state.selectedBot.id)}`,
						{
						lockOnAuthFailure: false,
						},
					);
					if (result.status !== "approved") return;
					await enterApp(result);
				} catch (error) {
					stopLoginPolling();
					setMessage(nodes.loginTelegramMessage, `Authorization failed: ${error.message}`, "error");
				}
			}

			async function enterApp(session) {
				stopLoginPolling();
				state.csrf = session.csrf;
				sessionStorage.setItem("silentflare_bot_csrf", state.csrf);
				const sessionBot = session.bot;
				if (sessionBot) state.bots = [sessionBot];
				state.selectedBot = sessionBot ?? state.selectedBot;
				nodes.totpState.textContent = session.totp_enabled ? "2FA enabled" : "2FA not configured";
				nodes.loginPage.classList.add("hidden");
				nodes.appPage.classList.remove("hidden");
				renderBots();
				renderActivity();
				if (state.selectedBot) selectBot(state.selectedBot);
				addActivity("Bot access verified", state.selectedBot?.id ?? "", "success");
			}

			function renderBots() {
				nodes.botList.textContent = "";
				if (state.bots.length === 0) {
					const empty = document.createElement("div");
					empty.className = "message";
					empty.textContent = "No bots available.";
					nodes.botList.append(empty);
					return;
				}
				for (const bot of state.bots) {
					const button = document.createElement("button");
					button.type = "button";
					button.className = "bot-card";
					button.setAttribute("aria-pressed", String(state.selectedBot?.id === bot.id));
					button.innerHTML = `<span class="bot-icon">${icon("bot")}</span><span><strong></strong><small></small></span>`;
					button.querySelector("strong").textContent = bot.id;
					button.querySelector("small").textContent = `${bot.purpose} / ${bot.status}`;
					button.addEventListener("click", () => selectBot(bot));
					nodes.botList.append(button);
				}
			}

			function selectBot(bot) {
				state.selectedBot = bot;
				nodes.pageTitle.textContent = bot.name;
				nodes.pageSubtitle.textContent = `Managing ${bot.id}. Operations require this Owner session and CSRF.`;
				nodes.selectedStatus.textContent = bot.status;
				nodes.selectedStatus.className = "chip";
				setMessage(nodes.selectedMessage, `${bot.purpose} backend loaded for ${bot.id}.`, "success");
				for (const button of [nodes.refreshStatus, nodes.telegramTest, nodes.runBackup]) button.disabled = false;
				renderBots();
				loadStatus();
				startStatusAutoRefresh();
				addActivity("Bot selected", bot.id, "neutral");
			}

			function startStatusAutoRefresh() {
				if (state.statusTimer) return;
				nodes.backupAuto.textContent = "Auto refresh: 30s";
				state.statusTimer = window.setInterval(() => {
					if (document.visibilityState !== "hidden" && state.selectedBot) loadStatus({ quiet: true });
				}, 30000);
			}

			function stopStatusAutoRefresh() {
				if (state.statusTimer) window.clearInterval(state.statusTimer);
				state.statusTimer = null;
				nodes.backupAuto.textContent = "Auto refresh paused";
			}

			function formatSize(value) {
				if (!Number.isFinite(value)) return "0 B";
				if (value < 1024) return `${value} B`;
				if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
				return `${(value / 1024 / 1024).toFixed(1)} MB`;
			}

			function shortSha(value) {
				if (!value) return "Unavailable";
				return `${value.slice(0, 10)}...${value.slice(-8)}`;
			}

			function renderStatus(status) {
				nodes.backupTimer.textContent = status.timer_active ? "Active" : "Inactive";
				nodes.backupLatest.textContent = status.latest?.created_at ?? "None";
				nodes.backupCount.textContent = `${status.backups.length} files`;
				nodes.backupHistory.textContent = "";
				if (status.backups.length === 0) {
					nodes.backupHistory.innerHTML = '<tr><td colspan="5"><div class="empty-state">No local backups found.</div></td></tr>';
					return;
				}
				for (const item of status.backups) {
					const row = document.createElement("tr");
					for (const value of [
						item.filename,
						item.created_at,
						formatSize(item.size),
						shortSha(item.sha256),
						"Success",
					]) {
						const cell = document.createElement("td");
						cell.textContent = value;
						if (value === item.filename || value === shortSha(item.sha256)) cell.className = "mono";
						row.append(cell);
					}
					nodes.backupHistory.append(row);
				}
			}

			async function loadStatus(options = {}) {
				if (!state.selectedBot) return;
				try {
					const status = await api(`/bots/${state.selectedBot.id}/backup/status`);
					renderStatus(status);
					if (!options.quiet) addActivity("Backup status loaded", state.selectedBot.id, "success");
				} catch (error) {
					setMessage(nodes.selectedMessage, `Unable to load backup status: ${error.message}`, "error");
					if (!options.quiet) addActivity("Backup status failed", error.message, "error");
				}
			}

			async function runBackup() {
				if (!state.selectedBot) return;
				nodes.runBackup.disabled = true;
				setMessage(nodes.selectedMessage, "Backup job started.");
				addActivity("Backup started", state.selectedBot.id, "pending");
				try {
					const result = await api(`/bots/${state.selectedBot.id}/backup/run`, {
						method: "POST",
						csrf: true,
					});
					setMessage(nodes.selectedMessage, result.message ?? "Backup completed.", "success");
					addActivity("Backup completed", result.latest?.filename ?? state.selectedBot.id, "success");
					await loadStatus({ quiet: true });
				} catch (error) {
					setMessage(nodes.selectedMessage, `Backup failed: ${error.message}`, "error");
					addActivity("Backup failed", error.message, "error");
				} finally {
					nodes.runBackup.disabled = false;
				}
			}

			async function testTelegram() {
				if (!state.selectedBot) return;
				nodes.telegramTest.disabled = true;
				try {
					const result = await api(`/bots/${state.selectedBot.id}/telegram/test`, {
						method: "POST",
						csrf: true,
					});
					setMessage(nodes.selectedMessage, result.message ?? "Telegram test notification sent.", "success");
					addActivity("Telegram test sent", state.selectedBot.id, "success");
				} catch (error) {
					setMessage(nodes.selectedMessage, `Telegram test failed: ${error.message}`, "error");
					addActivity("Telegram test failed", error.message, "error");
				} finally {
					nodes.telegramTest.disabled = false;
				}
			}

			function showView(view) {
				const settings = view === "settings";
				nodes.dashboardView.classList.toggle("hidden", settings);
				nodes.settingsView.classList.toggle("hidden", !settings);
				nodes.navDashboard.classList.toggle("active", !settings);
				nodes.navSettings.classList.toggle("active", settings);
			}

			async function generateTotp() {
				nodes.generateTotp.disabled = true;
				try {
					const result = await api("/settings/totp/generate", {
						method: "POST",
						csrf: true,
					});
					state.totpSecret = result.secret;
					nodes.totpSecret.textContent = result.secret;
					nodes.totpUri.textContent = result.otpauth_uri;
					await QRCode.toCanvas(nodes.totpQr, result.otpauth_uri, {
						errorCorrectionLevel: "M",
						margin: 1,
						width: 176,
					});
					nodes.totpSecretBox.classList.remove("hidden");
					nodes.enableTotpForm.classList.remove("hidden");
					setMessage(nodes.settingsMessage, "Add the otpauth URI or manual secret to your authenticator, then enter the current code.", "warning");
					addActivity("2FA setup generated", "Secret returned to current browser only", "warning");
				} catch (error) {
					setMessage(nodes.settingsMessage, `Unable to generate 2FA setup: ${error.message}`, "error");
				} finally {
					nodes.generateTotp.disabled = false;
				}
			}

			async function enableTotp(event) {
				event.preventDefault();
				if (!state.totpSecret) return;
				try {
					const result = await api("/settings/totp/enable", {
						method: "POST",
						csrf: true,
						body: JSON.stringify({
							code: nodes.enableTotpCode.value,
							secret: state.totpSecret,
						}),
					});
					nodes.totpState.textContent = result.totp_enabled ? "2FA enabled" : "2FA not configured";
					state.totpSecret = "";
					nodes.enableTotpCode.value = "";
					nodes.totpSecretBox.classList.add("hidden");
					nodes.enableTotpForm.classList.add("hidden");
					setMessage(nodes.settingsMessage, "2FA reset complete.", "success");
					addActivity("2FA reset complete", "Owner authenticator updated", "success");
				} catch (error) {
					setMessage(nodes.settingsMessage, `Unable to enable 2FA: ${error.message}`, "error");
				}
			}

			async function restoreSession() {
				try {
					const session = await api("/auth/me", { lockOnAuthFailure: false });
					await enterApp(session);
				} catch {
					nodes.loginPage.classList.remove("hidden");
					nodes.appPage.classList.add("hidden");
				}
			}

			async function loadPublicBots() {
				try {
					const list = await api("/bots", { lockOnAuthFailure: false });
					state.bots = list.bots ?? [];
					const remembered = sessionStorage.getItem("silentflare_selected_bot");
					state.selectedBot = state.bots.find((bot) => bot.id === remembered) ?? null;
					renderLoginBots();
					setAuthControlsEnabled(false);
					setMessage(nodes.loginMessage, "Select a bot to continue to verification.", "neutral");
				} catch (error) {
					state.bots = [];
					renderLoginBots();
					setAuthControlsEnabled(false);
					setMessage(nodes.loginMessage, `Unable to load bots: ${error.message}`, "error");
				}
			}

			async function boot() {
				renderActivity();
				setAuthControlsEnabled(false);
				await loadPublicBots();
				try {
					const options = await api("/auth/options", { lockOnAuthFailure: false });
					state.loginMethods = options.methods;
					setAuthControlsEnabled(false);
					setMessage(
						nodes.loginMessage,
						"Select a bot to continue to verification.",
						options.methods.telegram || options.methods.totp ? "success" : "error",
					);
				} catch (error) {
					setMessage(nodes.loginMessage, `Unable to load login methods: ${error.message}`, "error");
				}
				await restoreSession();
			}

			nodes.loginTelegram.addEventListener("click", startTelegramLogin);
			nodes.loginTotpForm.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (!state.selectedBot) {
					setMessage(nodes.loginMessage, "Select a bot before verification.", "warning");
					return;
				}
				try {
					const result = await api("/auth/login", {
						method: "POST",
						body: JSON.stringify({
							bot_id: state.selectedBot.id,
							code: nodes.loginTotpCode.value,
							method: "totp",
						}),
						lockOnAuthFailure: false,
					});
					await enterApp(result);
				} catch (error) {
					setMessage(nodes.loginMessageAuth, `2FA login failed: ${error.message}`, "error");
				}
			});
			nodes.changeBot.addEventListener("click", showBotStep);
			nodes.logout.addEventListener("click", async () => {
				try {
					await api("/auth/logout", { method: "POST", csrf: true });
				} catch {
					// The local state still clears if the server session already expired.
				}
				state.csrf = "";
				sessionStorage.removeItem("silentflare_bot_csrf");
				state.selectedBot = null;
				stopStatusAutoRefresh();
				nodes.appPage.classList.add("hidden");
				nodes.loginPage.classList.remove("hidden");
				await loadPublicBots();
			});
			nodes.refreshStatus.addEventListener("click", () => loadStatus());
			nodes.runBackup.addEventListener("click", runBackup);
			nodes.telegramTest.addEventListener("click", testTelegram);
			nodes.navDashboard.addEventListener("click", () => showView("dashboard"));
			nodes.navSettings.addEventListener("click", () => showView("settings"));
			nodes.generateTotp.addEventListener("click", generateTotp);
			nodes.enableTotpForm.addEventListener("submit", enableTotp);
			$("clear-activity").addEventListener("click", () => {
				state.activity = [];
				renderActivity();
			});

			boot();
		</script>
	</body>
</html>
