---
import type { GetStaticPaths } from "astro";
import Pagination from "../../components/control/Pagination.astro";
import PostPage from "../../components/PostPage.astro";
import { PAGE_SIZE } from "../../constants/constants";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { getAuthorList, getPostsForAuthor } from "../../utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const authors = await getAuthorList();
	const paths = [];
	for (const author of authors) {
		const posts = await getPostsForAuthor(author.slug);
		paths.push(
			...paginate(posts, {
				pageSize: PAGE_SIZE,
				params: { slug: author.slug },
				props: { author },
			}),
		);
	}
	return paths;
}) satisfies GetStaticPaths;

const { page, author } = Astro.props;
const len = page.data.length;
const description = author.bio ?? `Posts by ${author.name}`;
---

<MainGridLayout title={author.metaTitle ?? author.name} description={author.metaDescription ?? description}>
    <PostPage page={page}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}></Pagination>
</MainGridLayout>
