GHOST_URL=https://cms.silentflare.com
GHOST_CONTENT_API_KEY=replace_with_your_content_api_key
GHOST_API_VERSION=v5.0
SITE_URL=https://blog.silentflare.com
PUBLIC_API_BASE_URL=https://api.silentflare.com

# Optional build-time source override. Useful when building through an SSH
# tunnel such as GHOST_URL=http://127.0.0.1:23680 while Ghost is configured for
# https://cms.silentflare.com.
# GHOST_REQUEST_HOST=cms.silentflare.com
# GHOST_REQUEST_PROTO=https

# Optional local-only preview switch. Use when you want to verify the Astro UI
# without a configured Ghost instance. Do not enable this in production.
GHOST_ALLOW_EMPTY=false
