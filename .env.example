GHOST_URL=https://cms.silentflare.com
GHOST_CONTENT_API_KEY=replace_with_your_content_api_key
GHOST_API_VERSION=v5.0
SITE_URL=https://blog.silentflare.com
PUBLIC_API_BASE_URL=https://api.silentflare.com

# Cloudflare Turnstile. PUBLIC_* is safe for the browser.
PUBLIC_TURNSTILE_SITE_KEY=

# Backend-only Cloudflare Pages Functions values. Use `.dev.vars` locally and
# Cloudflare Pages variables/secrets in production. Do not expose these in the
# front end.
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAMES=auth.silentflare.com,accounts.silentflare.com,silentflare.com,www.silentflare.com
# Legacy fallback if TURNSTILE_EXPECTED_HOSTNAMES is unset:
# TURNSTILE_EXPECTED_HOSTNAME=accounts.silentflare.com
SESSION_COOKIE_NAME=sf_session
SESSION_SECRET=
ACCOUNT_SESSION_COOKIE_NAME=sf_account_session
ACCOUNT_COOKIE_DOMAIN=.silentflare.com
ACCOUNT_DB_PATH=/opt/silentflare/api/account.db
ACCOUNT_AVATAR_DIR=/opt/silentflare/api/uploads/avatars
ACCOUNT_AVATAR_PUBLIC_BASE=https://api.silentflare.com/account-avatars
ACCOUNT_AVATAR_MAX_BYTES=2097152
IP_GEOLOCATION_URL_TEMPLATE=https://ipwho.is/{ip}
IP_GEO_CACHE_TTL=86400

# Unified public authentication. Backend-only values belong in the FNS1 API
# env file. AUTH_EMAIL_API_KEY is a Resend-compatible API key and must never be
# exposed through PUBLIC_* variables or committed with a real value.
AUTH_EMAIL_API_KEY=
AUTH_EMAIL_FROM=verify@auth.silentflare.com
AUTH_EMAIL_API_URL=https://api.resend.com/emails
AUTH_LOGIN_VERIFY_URL=https://auth.silentflare.com/
AUTH_REGISTER_VERIFY_URL=https://accounts.silentflare.com/
AUTH_TOS_VERSION=2026-06-28
AUTH_EMAIL_CODE_TTL=600
AUTH_EMAIL_SEND_COOLDOWN=60
AUTH_EMAIL_SEND_LIMIT=5
AUTH_CODE_ATTEMPT_LIMIT=5
AUTH_FLOW_TTL=1200

# Optional build-time source override. Useful when building through an SSH
# tunnel such as GHOST_URL=http://127.0.0.1:23680 while Ghost is configured for
# https://cms.silentflare.com.
# GHOST_REQUEST_HOST=cms.silentflare.com
# GHOST_REQUEST_PROTO=https

# Optional local-only preview switch. Use when you want to verify the Astro UI
# without a configured Ghost instance. Do not enable this in production.
GHOST_ALLOW_EMPTY=false
